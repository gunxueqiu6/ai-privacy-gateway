<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow JIT compilation for Python/PyInstaller runtime -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow PyInstaller bootloader to execute writable memory -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow serving HTTP on localhost -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- Allow outbound HTTPS requests (AI API calls) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Allow reading files (config, vault data) -->
    <key>com.apple.security.files.user-selected.read-only</key>
    <true/>
</dict>
</plist>
