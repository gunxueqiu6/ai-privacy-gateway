<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0a0a0f"
    tools:context=".MainActivity">

    <!-- Logo -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🛡️"
        android:textSize="48sp"
        android:textAlignment="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AI Privacy Gateway"
        android:textSize="24sp"
        android:textColor="#4ade80"
        android:textAlignment="center"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <!-- VPN Switch -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#111118"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AI隐私保护"
            android:textSize="18sp"
            android:textColor="#ffffff" />

        <Switch
            android:id="@+id/switch_vpn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:thumbTint="#4ade80"
            android:trackTint="#22c55e" />
    </LinearLayout>

    <!-- Stats -->
    <TextView
        android:id="@+id/text_stats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠️ 保护未开启"
        android:textSize="14sp"
        android:textColor="#94a3b8"
        android:textAlignment="center"
        android:padding="16dp"
        android:background="#111118"
        android:layout_marginBottom="32dp" />

    <!-- Gateway Config -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="网关配置"
        android:textSize="16sp"
        android:textColor="#4ade80"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/edit_gateway_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="网关地址 (如 http://localhost:9999)"
        android:textColorHint="#94a3b8"
        android:textColor="#ffffff"
        android:background="#111118"
        android:padding="12dp"
        android:layout_marginBottom="8dp"
        android:inputType="textUri" />

    <EditText
        android:id="@+id/edit_api_key"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="API Key (可选)"
        android:textColorHint="#94a3b8"
        android:textColor="#ffffff"
        android:background="#111118"
        android:padding="12dp"
        android:layout_marginBottom="16dp"
        android:inputType="textPassword" />

    <Button
        android:id="@+id/btn_save_config"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="保存配置"
        android:background="#4ade80"
        android:textColor="#0a0a0f"
        android:textStyle="bold"
        android:padding="12dp" />

    <!-- Info -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="说明：开启后，所有AI服务请求（ChatGPT、DeepSeek、Claude等）将自动通过网关脱敏处理，保护您的隐私数据。"
        android:textSize="12sp"
        android:textColor="#94a3b8"
        android:textAlignment="center" />

</LinearLayout>