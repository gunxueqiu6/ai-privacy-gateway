# AI Privacy Gateway 配置文件
# 复制此文件为 .env 并根据需要修改

# 目标 AI API 地址（默认 OpenAI）
TARGET_LLM=https://api.openai.com

# 网关监听端口
LISTEN_PORT=9999

# SQLite 数据库路径
DB_PATH=./vault_data/privacy_vault.db

# 数据库类型 (sqlite)
DB_TYPE=sqlite

# 脱敏引擎类型 (regex)
MASK_ENGINE_TYPE=regex

# 上游 API Key（可选，如目标 AI 服务需要认证）
UPSTREAM_API_KEY=

# 管理员密码（留空则自动生成）
ADMIN_PASSWORD=

# JWT 签名密钥（留空则自动生成）
JWT_SECRET=

# Vault 加密密钥（留空则禁用加密，自动生成随机密钥）
VAULT_ENCRYPT_KEY=

# Dry-Run 模式（1=启用，检测敏感信息仅记录日志，不实际脱敏，不写入 Vault）
DRY_RUN_MODE=0

# 速率限制存储后端（memory:// 或 redis://host:port/db）
RATE_LIMIT_STORAGE=memory://

# 并发与安全
# MAX_CONCURRENT_REQUESTS=50
# SHUTDOWN_TIMEOUT=30
# MAX_REQUEST_BODY_SIZE=10485760

# SSL/TLS 配置（留空 = 不启用 TLS）
# SSL_CERTFILE=/path/to/cert.pem
# SSL_KEYFILE=/path/to/key.pem
