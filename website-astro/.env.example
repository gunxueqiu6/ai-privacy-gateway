# Cloudflare Pages 环境变量
# 复制此文件为 .env 并填入真实值

# API 代理地址（demo 页面使用）
PUBLIC_API_BASE=https://surf-illinois-servers-wrote.trycloudflare.com

# ============================================================
# 搜索引擎站长验证码 — 在对应平台添加站点后获取
# ============================================================

# 百度 https://ziyuan.baidu.com/site/
PUBLIC_BAIDU_VERIFICATION=

# Google https://search.google.com/search-console
PUBLIC_GOOGLE_VERIFICATION=

# 360 https://zhanzhang.so.com/
PUBLIC_SO360_VERIFICATION=

# 搜狗 https://zhanzhang.sogou.com/
PUBLIC_SOGOU_VERIFICATION=

# 必应 https://www.bing.com/webmasters/
PUBLIC_BING_VERIFICATION=

# 神马 https://zhanzhang.sm.cn/
PUBLIC_SHENMA_VERIFICATION=

# 字节跳动（头条） https://zhanzhang.toutiao.com/
PUBLIC_BYTEDANCE_VERIFICATION=
