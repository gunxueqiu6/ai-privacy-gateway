---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { t } from '../i18n/translations';
import { getLangFromURL } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  frontmatter?: Record<string, any>;
}

const lang = getLangFromURL(Astro.url.pathname);

const {
  title,
  description = 'AI Privacy Gateway technical docs — quick start, deployment, configuration, API reference, architecture',
  canonicalURL = 'https://privacygw.pages.dev/docs',
  frontmatter = {},
} = Astro.props;

const fm = frontmatter || {};
const pageTitle = fm.title ? `${fm.title} | AI Privacy Gateway` : title;
const pageDescription = fm.description || description;
const pageUrl = fm.canonicalURL || canonicalURL;

const htmlLang = lang === 'zh' ? 'zh-CN' : 'en';
const ogLocale = lang === 'zh' ? 'zh_CN' : 'en_US';
const kw = lang === 'zh'
  ? 'AI隐私,数据脱敏,隐私网关,LLM安全,技术文档,部署指南,API参考,架构说明'
  : 'AI privacy, data masking, privacy gateway, LLM security, technical docs, deployment, API reference, architecture';
---

<!doctype html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription}>
  <meta name="keywords" content={kw}>
  <meta name="robots" content="index, follow">
  {import.meta.env.PUBLIC_BAIDU_VERIFICATION && <meta name="baidu-site-verification" content={import.meta.env.PUBLIC_BAIDU_VERIFICATION}>}
  {import.meta.env.PUBLIC_GOOGLE_VERIFICATION && <meta name="google-site-verification" content={import.meta.env.PUBLIC_GOOGLE_VERIFICATION}>}
  {import.meta.env.PUBLIC_SO360_VERIFICATION && <meta name="360-site-verification" content={import.meta.env.PUBLIC_SO360_VERIFICATION}>}
  {import.meta.env.PUBLIC_SOGOU_VERIFICATION && <meta name="sogou_site_verification" content={import.meta.env.PUBLIC_SOGOU_VERIFICATION}>}
  {import.meta.env.PUBLIC_BING_VERIFICATION && <meta name="msvalidate.01" content={import.meta.env.PUBLIC_BING_VERIFICATION}>}
  {import.meta.env.PUBLIC_SHENMA_VERIFICATION && <meta name="shenma-site-verification" content={import.meta.env.PUBLIC_SHENMA_VERIFICATION}>}
  {import.meta.env.PUBLIC_BYTEDANCE_VERIFICATION && <meta name="bytedance-verification-code" content={import.meta.env.PUBLIC_BYTEDANCE_VERIFICATION}>}
  <link rel="canonical" href={pageUrl}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <meta property="og:title" content={pageTitle}>
  <meta property="og:description" content={pageDescription}>
  <meta property="og:type" content="article">
  <meta property="og:url" content={pageUrl}>
  <meta property="og:image" content="https://privacygw.pages.dev/og-image.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:locale" content={ogLocale}>
  <meta property="og:site_name" content="AI Privacy Gateway">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={pageTitle}>
  <meta name="twitter:description" content={pageDescription}>
  <meta name="twitter:image" content="https://privacygw.pages.dev/og-image.png">

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: pageTitle,
    description: pageDescription,
    author: { '@type': 'Organization', name: 'AI Privacy Gateway' },
    publisher: { '@type': 'Organization', name: 'AI Privacy Gateway', url: 'https://privacygw.pages.dev' }
  })} />
  <style is:global>
    @import '../styles/global.css';
  </style>
</head>
<body>
  <div class="gradient-orb gradient-orb-1"></div>
  <div class="gradient-orb gradient-orb-2"></div>
  <Nav />

  <main class="docs-layout">
    <aside class="docs-sidebar glass">
      <nav>
        <h4>{t(lang, 'docs.nav_title')}</h4>
        <a href="/docs/quickstart">{t(lang, 'docs.nav_quickstart')}</a>
        <a href="/docs/deploy">{t(lang, 'docs.nav_deploy')}</a>
        <a href="/docs/config">{t(lang, 'docs.nav_config')}</a>
        <a href="/docs/keywords">{t(lang, 'docs.nav_keywords')}</a>
        <a href="/docs/architecture">{t(lang, 'docs.nav_architecture')}</a>
        <a href="/docs/api">{t(lang, 'docs.nav_api')}</a>
      </nav>
    </aside>

    <article class="docs-content">
      <slot />
    </article>
  </main>

  <Footer />
</body>
</html>

<style>
  .docs-layout {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    gap: 3rem;
    padding: 8rem 2rem 4rem;
    position: relative;
    z-index: 1;
  }

  .docs-sidebar {
    width: 220px;
    flex-shrink: 0;
    padding: 1.5rem;
    position: sticky;
    top: 6rem;
    align-self: flex-start;
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
  }

  .docs-sidebar h4 {
    color: var(--text-muted);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .docs-sidebar a {
    display: block;
    padding: 0.5rem 0.75rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .docs-sidebar a:hover {
    color: var(--primary);
    background: rgba(134, 239, 172, 0.05);
  }

  .docs-content {
    flex: 1;
    min-width: 0;
  }

  .docs-content :global(h1) {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .docs-content :global(h2) {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 2.5rem 0 1rem;
    color: var(--text-primary);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .docs-content :global(h3) {
    color: var(--text-primary);
    font-weight: 600;
    margin: 1.5rem 0 0.75rem;
    font-size: 1.1rem;
  }

  .docs-content :global(p) {
    color: var(--text-secondary);
    margin-bottom: 1rem;
    line-height: 1.8;
  }

  .docs-content :global(ul), .docs-content :global(ol) {
    color: var(--text-secondary);
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .docs-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .docs-content :global(pre) {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }

  .docs-content :global(code) {
    font-family: 'Fira Code', 'Cascadia Code', 'JetBrains Mono', monospace;
    font-size: 0.88rem;
  }

  .docs-content :global(:not(pre) > code) {
    background: var(--bg-surface);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.85rem;
    color: var(--primary);
  }

  .docs-content :global(blockquote) {
    border-left: 2px solid var(--primary);
    padding-left: 1rem;
    color: var(--text-secondary);
    margin-bottom: 1rem;
    font-style: italic;
  }

  .docs-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.25rem;
  }

  .docs-content :global(th), .docs-content :global(td) {
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .docs-content :global(th) {
    color: var(--text-primary);
    font-weight: 600;
    font-size: 0.85rem;
    background: var(--bg-surface);
  }

  .docs-content :global(td) {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .docs-content :global(tr:hover td) {
    background: rgba(134, 239, 172, 0.03);
  }

  @media (max-width: 768px) {
    .docs-layout {
      flex-direction: column;
      padding: 6rem 1rem 3rem;
    }

    .docs-sidebar {
      width: 100%;
      position: static;
      max-height: none;
    }

    .docs-sidebar nav {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .docs-sidebar h4 {
      width: 100%;
    }

    .docs-sidebar a {
      padding: 0.35rem 0.75rem;
      font-size: 0.85rem;
    }
  }
</style>
