---
import { t } from '../i18n/translations';
import { getLangFromURL } from '../i18n/utils';

const lang = getLangFromURL(Astro.url.pathname);
const ft = { product: t(lang, 'footer.product'), home: t(lang, 'footer.home'), pricing: t(lang, 'footer.pricing'), demo: t(lang, 'footer.demo'), download: t(lang, 'footer.download'), docs: t(lang, 'footer.docs'), features: t(lang, 'footer.features'), resources: t(lang, 'footer.resources'), docs_link: t(lang, 'footer.docs_link'), api_reference: t(lang, 'footer.api_reference'), github: t(lang, 'footer.github'), privacy_policy: t(lang, 'footer.privacy_policy'), terms_of_service: t(lang, 'footer.terms_of_service'), company: t(lang, 'footer.company'), about: t(lang, 'footer.about'), contact: t(lang, 'footer.contact'), copyright: t(lang, 'footer.copyright') };
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col footer-brand-col">
        <div class="footer-brand">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <path d="M9 12l2 2 4-4"/>
          </svg>
          <span>Privacy Gateway</span>
        </div>
        <p class="footer-tagline">{ft.copyright}</p>
        <div class="footer-social">
          <a href="https://github.com/gunxueqiu6/ai-privacy-gateway" class="social-link" aria-label="GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <h4>{ft.product}</h4>
        <a href="/#features">{ft.features}</a>
        <a href="/demo">{ft.demo}</a>
        <a href="/pricing">{ft.pricing}</a>
        <a href="/download">{ft.download}</a>
      </div>

      <div class="footer-col">
        <h4>{ft.docs}</h4>
        <a href="/docs/quickstart">{t(lang, 'docs.quickstart')}</a>
        <a href="/docs/deploy">{t(lang, 'docs.deploy')}</a>
        <a href="/docs/config">{t(lang, 'docs.config')}</a>
        <a href="/docs/api">{t(lang, 'docs.api')}</a>
      </div>

      <div class="footer-col">
        <h4>{ft.company}</h4>
        <a href="/privacy-policy">{ft.privacy_policy}</a>
        <a href="/terms-of-service">{ft.terms_of_service}</a>
        <a href="https://github.com/gunxueqiu6/ai-privacy-gateway/issues">{ft.contact}</a>
        <a href="https://t.me/chirstmas_7">Telegram</a>
        <a href="https://github.com/gunxueqiu6/ai-privacy-gateway">{ft.github}</a>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; 2026 AI Privacy Gateway. MIT Licensed. Open Source.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 5rem 0 2rem;
    border-top: 1px solid var(--border);
    position: relative;
    z-index: 1;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
  }

  .footer-brand svg {
    color: var(--primary);
  }

  .footer-tagline {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.7;
    margin-bottom: 1.25rem;
    max-width: 280px;
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: 1px solid var(--border);
    color: var(--text-muted);
    transition: all 0.25s ease;
  }

  @media (hover: hover) {
    .social-link:hover {
      border-color: var(--primary);
      color: var(--primary);
      background: rgba(134, 239, 172, 0.04);
    }
  }

  .footer-col h4 {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  .footer-col a {
    display: block;
    color: var(--text-secondary);
    font-size: 0.9rem;
    padding: 0.35rem 0;
    transition: color 0.2s ease;
  }

  @media (hover: hover) {
    .footer-col a:hover {
      color: var(--primary);
    }
  }

  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .footer-bottom p {
    color: var(--text-dim);
    font-size: 0.82rem;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .footer-brand-col {
      grid-column: 1 / -1;
    }
    .footer-tagline {
      max-width: 100%;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .footer { padding: 3rem 0 2rem; }
  }
</style>
