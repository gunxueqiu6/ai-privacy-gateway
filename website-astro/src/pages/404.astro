---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getLangFromURL } from '../i18n/utils';

const lang = getLangFromURL(Astro.url.pathname);

const title = lang === 'zh' ? '页面未找到 — AI Privacy Gateway' : 'Page Not Found — AI Privacy Gateway';
const subtitle = lang === 'zh'
  ? '这个页面好像被脱敏了……'
  : 'This page seems to have been masked...';
const desc = lang === 'zh'
  ? '我们找不到你访问的页面。它可能已经被移动、删除，或者 URL 输入有误。'
  : 'We could not find the page you are looking for. It may have been moved, deleted, or the URL may be incorrect.';
const cta = lang === 'zh' ? '返回首页' : 'Back to Home';
const hint = lang === 'zh'
  ? '别担心，你的数据依然是安全的。'
  : 'Don\'t worry — your data is still safe.';
---

<Layout title={title} description={desc} canonicalURL="https://privacygw.pages.dev/404">
  <Nav />

  <section class="error-hero">
    <div class="error-orb-1"></div>
    <div class="error-orb-2"></div>

    <div class="container error-content">
      <div class="error-code">
        <span class="error-digit">4</span>
        <span class="error-digit error-digit-zero">0</span>
        <span class="error-digit">4</span>
      </div>

      <div class="error-card glass">
        <h1 class="error-title">{subtitle}</h1>
        <p class="error-desc">{desc}</p>
        <p class="error-hint">{hint}</p>
        <a href="/" class="btn btn-primary error-cta">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          {cta}
        </a>
      </div>
    </div>
  </section>

  <Footer />

  <style>
    .error-hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
      padding: 6rem 0 4rem;
    }

    .error-orb-1 {
      position: absolute;
      top: 10%;
      left: 5%;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, var(--primary-glow) 0%, rgba(134, 239, 172, 0.04) 40%, transparent 70%);
      border-radius: 50%;
      filter: blur(100px);
      animation: orb-float 20s ease-in-out infinite;
      pointer-events: none;
    }

    .error-orb-2 {
      position: absolute;
      bottom: 10%;
      right: 5%;
      width: 550px;
      height: 550px;
      background: radial-gradient(circle, var(--accent-glow) 0%, rgba(167, 139, 250, 0.04) 40%, transparent 70%);
      border-radius: 50%;
      filter: blur(100px);
      animation: orb-float 25s ease-in-out infinite -8s;
      pointer-events: none;
    }

    .error-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2rem;
      position: relative;
      z-index: 1;
    }

    .error-code {
      display: flex;
      gap: 0.5rem;
      user-select: none;
    }

    .error-digit {
      font-size: 8rem;
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.06em;
      background: linear-gradient(135deg, var(--primary), var(--primary-dim));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: digit-pulse 3s ease-in-out infinite;
    }

    .error-digit-zero {
      background: linear-gradient(135deg, var(--accent), var(--primary));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation-delay: 0.5s;
    }

    @keyframes digit-pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.08); opacity: 0.85; }
    }

    .error-card {
      max-width: 480px;
      width: 100%;
      padding: 2.5rem 2rem;
      text-align: center;
    }

    .error-title {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      color: var(--text-primary);
    }

    .error-desc {
      font-size: 0.92rem;
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 0.75rem;
    }

    .error-hint {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
      font-style: italic;
    }

    .error-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    @media (max-width: 768px) {
      .error-hero {
        min-height: 90vh;
        padding: 5rem 0 3rem;
      }

      .error-digit {
        font-size: 5rem;
      }

      .error-card {
        padding: 2rem 1.5rem;
      }

      .error-title {
        font-size: 1.25rem;
      }

      .error-orb-1, .error-orb-2 {
        width: 300px;
        height: 300px;
        opacity: 0.4;
      }
    }

    @media (max-width: 480px) {
      .error-digit {
        font-size: 3.5rem;
      }

      .error-card {
        padding: 1.5rem 1.25rem;
      }
    }
  </style>
</Layout>
