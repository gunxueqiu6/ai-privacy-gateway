---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="定价 — AI Privacy Gateway | Lite 免费 · Pro ¥99/月 · Enterprise 定制"
  description="AI Privacy Gateway 提供三个版本：Lite 个人免费版（开源）、Pro 团队版 ¥99/月（20 人）、Enterprise 企业版（定制年费）。选择适合你的版本。"
  canonicalURL="https://privacygw.pages.dev/pricing">
  <Nav />

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        <span>透明定价，无隐藏费用</span>
      </div>
      <h1 class="hero-title">
        选择适合你的
        <span class="gradient-text">版本</span>
      </h1>
      <p class="hero-description">
        从个人开发者到大型企业，每个版本都为不同规模精心设计。<br/>
        Lite 版永久免费开源，Pro 版 7 天无理由退款。
      </p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="pricing-section">
    <div class="container pricing-grid">
      <!-- Lite -->
      <div class="pricing-card glass">
        <div class="tier-label">免费版</div>
        <h2>Lite</h2>
        <div class="pricing-price">
          <span class="price">免费</span>
        </div>
        <p class="pricing-desc">个人开发者永久免费</p>
        <ul class="pricing-features">
          <li class="feature-item">
            <span class="check">✓</span>
            <span>正则脱敏（手机号/邮箱/身份证/银行卡）</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>流式代理 + 缓冲区管理</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>自定义敏感词</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>基础管理后台</span>
          </li>
          <li class="feature-item disabled">
            <span class="cross">✗</span>
            <span>多人并发支持</span>
          </li>
          <li class="feature-item disabled">
            <span class="cross">✗</span>
            <span>团队看板</span>
          </li>
          <li class="feature-item disabled">
            <span class="cross">✗</span>
            <span>云端规则自动更新</span>
          </li>
        </ul>
        <a href="https://github.com/gunxueqiu6/ai-privacy-gateway" class="btn btn-outline btn-block">GitHub 下载</a>
      </div>

      <!-- Pro -->
      <div class="pricing-card popular">
        <div class="popular-badge">最受欢迎</div>
        <div class="tier-label">团队版</div>
        <h2>Pro</h2>
        <div class="pricing-price">
          <span class="price">¥99</span>
          <span class="period">/月</span>
        </div>
        <p class="pricing-desc">适合 20 人以下团队</p>
        <ul class="pricing-features">
          <li class="feature-item">
            <span class="check">✓</span>
            <span>全部 Lite 功能</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>多人并发（20 人）</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>SQLite WAL 模式</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>团队看板 + 会话查询</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>云端规则自动更新</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>日/周/月统计报告</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>邮件技术支持</span>
          </li>
        </ul>
        <a href="mailto:support@privacygw.com?subject=Pro%20版咨询" class="btn btn-primary btn-block">联系客服</a>
      </div>

      <!-- Enterprise -->
      <div class="pricing-card glass">
        <div class="tier-label">企业版</div>
        <h2>Enterprise</h2>
        <div class="pricing-price">
          <span class="price">定制</span>
          <span class="period">年费</span>
        </div>
        <p class="pricing-desc">适合大型企业部署</p>
        <ul class="pricing-features">
          <li class="feature-item">
            <span class="check">✓</span>
            <span>全部 Pro 功能</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>100+ 人高并发</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>Redis 集群存储</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>AC 自动机（万级词库）</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>审计日志 + 告警通知</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>权限控制 (RBAC)</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>驻场支持 + SLA 保障</span>
          </li>
        </ul>
        <a href="mailto:contact@privacygw.com?subject=Enterprise%20咨询" class="btn btn-outline btn-block">联系我们</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <h2 class="section-title">常见问题</h2>
      <div class="faq-grid">
        <div class="faq-card glass">
          <h4>如何获取 Pro 或 Enterprise 版？</h4>
          <p>请发送邮件至 <a href="mailto:support@privacygw.com">support@privacygw.com</a>，我们会根据您的团队规模和需求提供专属方案。</p>
        </div>
        <div class="faq-card glass">
          <h4>支持退款吗？</h4>
          <p>支持 7 天无理由退款。如果您对产品不满意，请发送邮件至 support@privacygw.com。</p>
        </div>
        <div class="faq-card glass">
          <h4>Lite 版可以商用吗？</h4>
          <p>Lite 版基于 MIT 许可证，可自由用于个人和商业项目。如需团队协作和高级功能，请考虑 Pro 版。</p>
        </div>
        <div class="faq-card glass">
          <h4>如何升级到 Enterprise 版？</h4>
          <p>请发送邮件至 <a href="mailto:support@privacygw.com">support@privacygw.com</a>，我们会根据您的需求提供定制方案。</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 10rem 0 4rem;
    position: relative;
  }

  .hero-content {
    text-align: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg-surface);
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--primary);
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    background: var(--primary);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-bottom: 1.5rem;
    line-height: 1.15;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.8;
    max-width: 560px;
    margin: 0 auto;
  }

  /* Pricing */
  .pricing-section {
    padding: 4rem 0 6rem;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 1200px;
  }

  .pricing-card {
    padding: 2.5rem;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .pricing-card.popular {
    border-color: var(--primary);
    box-shadow: 0 0 60px var(--primary-glow);
    transform: scale(1.03);
    background: rgba(134, 239, 172, 0.03);
    backdrop-filter: blur(24px);
    z-index: 1;
  }

  .popular-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, var(--primary-dim), var(--primary));
    color: var(--bg-deep);
    padding: 0.35rem 1.25rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .tier-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .pricing-card h2 {
    font-size: 1.75rem;
    margin-bottom: 1.25rem;
  }

  .pricing-price {
    margin-bottom: 0.5rem;
  }

  .pricing-price .price {
    font-size: 3rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .pricing-price .period {
    font-size: 1rem;
    color: var(--text-muted);
    margin-left: 0.25rem;
  }

  .pricing-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .pricing-features {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    flex: 1;
  }

  .feature-item {
    display: flex;
    align-items: center;
    padding: 0.65rem 0;
    font-size: 0.9rem;
    color: var(--text-secondary);
    gap: 0.75rem;
  }

  .feature-item.disabled {
    opacity: 0.4;
    text-decoration: line-through;
  }

  .check {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    background: rgba(134, 239, 172, 0.12);
    color: var(--primary);
    flex-shrink: 0;
  }

  .cross {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    background: rgba(248, 113, 113, 0.1);
    color: var(--danger);
    flex-shrink: 0;
  }

  .btn-outline {
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border);
    padding: 0.75rem 1.5rem;
  }

  .btn-outline:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  .btn-block {
    width: 100%;
  }

  /* FAQ */
  .faq-section {
    padding: 6rem 0;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 600;
    text-align: center;
    margin-bottom: 3rem;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .faq-card {
    padding: 1.5rem;
  }

  .faq-card h4 {
    color: var(--primary);
    margin-bottom: 0.5rem;
    font-size: 1rem;
  }

  .faq-card p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  @media (max-width: 1024px) {
    .pricing-grid { grid-template-columns: repeat(2, 1fr); }
    .pricing-card.popular { transform: none; }
  }

  @media (max-width: 768px) {
    .hero-title { font-size: 2.25rem; }
    .pricing-grid { grid-template-columns: 1fr; max-width: 400px; }
    .pricing-card.popular { transform: none; }
    .faq-grid { grid-template-columns: 1fr; }

  }
</style>
