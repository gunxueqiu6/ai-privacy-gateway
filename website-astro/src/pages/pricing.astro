---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="定价 — AI Privacy Gateway | Lite 免费 · Pro ¥99/月 · Enterprise 定制"
  description="AI Privacy Gateway 提供三个版本：Lite 个人免费版（开源）、Pro 团队版 ¥99/月（20 人）、Enterprise 企业版（定制年费）。选择适合你的版本。"
  canonicalURL="https://privacygw.pages.dev/pricing">
  <Nav />

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        <span>透明定价，无隐藏费用</span>
      </div>
      <h1 class="hero-title">
        选择适合你的
        <span class="gradient-text">版本</span>
      </h1>
      <p class="hero-description">
        从个人开发者到大型企业，每个版本都为不同规模精心设计。<br/>
        Lite 版永久免费开源，Pro 版 7 天无理由退款。
      </p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="pricing-section">
    <div class="container pricing-grid">
      <!-- Lite -->
      <div class="pricing-card glass">
        <div class="tier-label">免费版</div>
        <h2>Lite</h2>
        <div class="pricing-price">
          <span class="price">免费</span>
        </div>
        <p class="pricing-desc">个人开发者永久免费</p>
        <ul class="pricing-features">
          <li class="feature-item">
            <span class="check">✓</span>
            <span>正则脱敏（手机号/邮箱/身份证/银行卡）</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>流式代理 + 缓冲区管理</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>自定义敏感词</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>基础管理后台</span>
          </li>
          <li class="feature-item disabled">
            <span class="cross">✗</span>
            <span>多人并发支持</span>
          </li>
          <li class="feature-item disabled">
            <span class="cross">✗</span>
            <span>团队看板</span>
          </li>
          <li class="feature-item disabled">
            <span class="cross">✗</span>
            <span>云端规则自动更新</span>
          </li>
        </ul>
        <a href="https://github.com/gunxueqiu6/ai-privacy-gateway" class="btn btn-outline btn-block">GitHub 下载</a>
      </div>

      <!-- Pro -->
      <div class="pricing-card popular">
        <div class="popular-badge">最受欢迎</div>
        <div class="tier-label">团队版</div>
        <h2>Pro</h2>
        <div class="pricing-price">
          <span class="price">¥99</span>
          <span class="period">/月</span>
        </div>
        <p class="pricing-desc">适合 20 人以下团队</p>
        <ul class="pricing-features">
          <li class="feature-item">
            <span class="check">✓</span>
            <span>全部 Lite 功能</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>多人并发（20 人）</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>SQLite WAL 模式</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>团队看板 + 会话查询</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>云端规则自动更新</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>日/周/月统计报告</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>邮件技术支持</span>
          </li>
        </ul>
        <button class="btn btn-primary btn-block" onclick="openCheckout('pro')">立即购买</button>
      </div>

      <!-- Enterprise -->
      <div class="pricing-card glass">
        <div class="tier-label">企业版</div>
        <h2>Enterprise</h2>
        <div class="pricing-price">
          <span class="price">定制</span>
          <span class="period">年费</span>
        </div>
        <p class="pricing-desc">适合大型企业部署</p>
        <ul class="pricing-features">
          <li class="feature-item">
            <span class="check">✓</span>
            <span>全部 Pro 功能</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>100+ 人高并发</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>Redis 集群存储</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>AC 自动机（万级词库）</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>审计日志 + 告警通知</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>权限控制 (RBAC)</span>
          </li>
          <li class="feature-item">
            <span class="check">✓</span>
            <span>驻场支持 + SLA 保障</span>
          </li>
        </ul>
        <a href="mailto:contact@privacygw.com?subject=Enterprise%20咨询" class="btn btn-outline btn-block">联系我们</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <h2 class="section-title">常见问题</h2>
      <div class="faq-grid">
        <div class="faq-card glass">
          <h4>购买后如何获取 License Key？</h4>
          <p>购买完成后，License Key 会发送到您的邮箱。在管理后台输入 Key 即可激活 Pro 版功能。</p>
        </div>
        <div class="faq-card glass">
          <h4>支持退款吗？</h4>
          <p>支持 7 天无理由退款。如果您对产品不满意，请发送邮件至 support@privacygw.com。</p>
        </div>
        <div class="faq-card glass">
          <h4>License 可以在多台机器使用吗？</h4>
          <p>Pro 版 License 绑定硬件指纹，支持最多 3 台设备轮换。如需更多设备，请联系我们升级。</p>
        </div>
        <div class="faq-card glass">
          <h4>如何升级到 Enterprise 版？</h4>
          <p>请发送邮件至 contact@privacygw.com，我们会根据您的需求提供定制方案。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Checkout Modal -->
  <div class="checkout-overlay" id="checkoutOverlay" style="display:none">
    <div class="checkout-modal">
      <button class="checkout-close" onclick="closeCheckout()">&times;</button>
      <h3 id="checkoutTitle">购买 Pro 版</h3>
      <p class="checkout-price" id="checkoutPrice">¥99/月</p>

      <div id="checkoutStep1">
        <label class="checkout-label">邮箱地址（用于接收 License Key）</label>
        <input type="email" id="customerEmail" class="checkout-input" placeholder="your@email.com" required>

        <div class="checkout-methods">
          <button class="payment-method-btn active" onclick="selectPayment('wechat')" id="wechatTab">
            <span class="method-icon">💚</span> 微信支付
          </button>
          <button class="payment-method-btn" onclick="selectPayment('alipay')" id="alipayTab">
            <span class="method-icon">💙</span> 支付宝
          </button>
          <button class="payment-method-btn" onclick="selectPayment('paypal')" id="paypalTab">
            <span class="method-icon">💳</span> PayPal
          </button>
        </div>

        <div id="wechatSection" class="payment-section">
          <div class="wechat-pay-info">
            <div class="qr-code-container">
              <div class="qr-code-frame" id="wechatQrCode">
                <div class="qr-loading">
                  <div class="spinner"></div>
                  <p>正在生成支付二维码...</p>
                </div>
              </div>
              <div class="qr-refresh">
                <button class="btn btn-outline btn-sm" onclick="refreshWechatQr()">刷新二维码</button>
              </div>
            </div>
            <p class="payment-note">微信扫码支付 ¥99</p>
            <div class="payment-status" id="wechatStatus">
              <span>等待支付...</span>
            </div>
            <p class="payment-tip">支付完成后，License Key 将自动发送到您的邮箱</p>
          </div>
        </div>

        <div id="alipaySection" class="payment-section" style="display:none">
          <div class="alipay-pay-info">
            <div class="qr-code-container">
              <div class="qr-code-frame" id="alipayQrCode">
                <div class="qr-loading">
                  <div class="spinner"></div>
                  <p>正在生成支付二维码...</p>
                </div>
              </div>
              <div class="qr-refresh">
                <button class="btn btn-outline btn-sm" onclick="refreshAlipayQr()">刷新二维码</button>
              </div>
            </div>
            <p class="payment-note">支付宝扫码支付 ¥99</p>
            <div class="payment-status" id="alipayStatus">
              <span>等待支付...</span>
            </div>
            <p class="payment-tip">支付完成后，License Key 将自动发送到您的邮箱</p>
          </div>
        </div>

        <div id="paypalSection" class="payment-section" style="display:none">
          <div id="paypal-button-container" style="margin-top:1rem"></div>
        </div>
      </div>

      <div id="checkoutStep2" style="display:none">
        <div class="success-icon">&#10003;</div>
        <h4>购买成功！</h4>
        <p class="success-text">License Key 已发送到您的邮箱</p>
        <div class="license-display" id="licenseDisplay"></div>
        <p class="success-note">请检查收件箱（或垃圾邮件箱）</p>
        <button class="btn btn-primary" onclick="closeCheckout()">关闭</button>
      </div>
    </div>
  </div>

  <Footer />

  <script src="https://www.paypal.com/sdk/js?client-id=AXO6jh-66p-C8s_kaBXq9JVQN4MVpHj5uZztJv-8k6ut5Z-B9c97BYBTtPxC90Uij1DT7cl0ytsPiukq&currency=CNY&intent=capture" async></script>
  <script is:inline>
    const LICENSE_SERVER = 'https://149.104.12.203';
    let selectedTier = 'pro';
    let selectedPayment = 'wechat';
    let currentOrderId = null;
    let paymentPollInterval = null;

    function openCheckout(tier) {
      selectedTier = tier;
      const overlay = document.getElementById('checkoutOverlay');
      const title = document.getElementById('checkoutTitle');
      const price = document.getElementById('checkoutPrice');
      if (tier === 'pro') {
        title.textContent = '购买 Pro 版';
        price.textContent = '¥99/月';
      } else {
        title.textContent = '咨询 Enterprise 版';
        price.textContent = '定制年费';
      }
      document.getElementById('checkoutStep1').style.display = 'block';
      document.getElementById('checkoutStep2').style.display = 'none';
      overlay.style.display = 'flex';
      if (tier === 'pro') {
        selectPayment('wechat');
      }
    }

    function closeCheckout() {
      document.getElementById('checkoutOverlay').style.display = 'none';
      stopPaymentPolling();
    }

    function selectPayment(method) {
      selectedPayment = method;
      document.getElementById('paypalTab').classList.toggle('active', method === 'paypal');
      document.getElementById('wechatTab').classList.toggle('active', method === 'wechat');
      document.getElementById('alipayTab').classList.toggle('active', method === 'alipay');
      document.getElementById('paypalSection').style.display = method === 'paypal' ? 'block' : 'none';
      document.getElementById('wechatSection').style.display = method === 'wechat' ? 'block' : 'none';
      document.getElementById('alipaySection').style.display = method === 'alipay' ? 'block' : 'none';

      stopPaymentPolling();

      if (method === 'paypal') {
        setTimeout(renderPayPalButton, 200);
      } else if (method === 'wechat') {
        createWechatPayment();
      } else if (method === 'alipay') {
        createAlipayPayment();
      }
    }

    function renderPayPalButton() {
      const container = document.getElementById('paypal-button-container');
      if (!container || typeof paypal === 'undefined') return;
      container.innerHTML = '';
      paypal.Buttons({
        style: { layout: 'vertical', color: 'gold', shape: 'rect', label: 'paypal' },
        createOrder: function(data, actions) {
          return actions.order.create({
            purchase_units: [{
              description: 'AI Privacy Gateway Pro — 月度订阅',
              amount: { currency_code: 'CNY', value: '99.00' }
            }]
          });
        },
        onApprove: function(data, actions) {
          const email = document.getElementById('customerEmail').value.trim();
          if (!email) { alert('请先输入邮箱地址'); return; }
          fetch(`${LICENSE_SERVER}/api/payment/complete`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              order_id: data.orderID,
              customer_email: email,
              tier: selectedTier,
              expires_in_days: 365,
              max_concurrent: 20
            })
          })
          .then(r => r.json())
          .then(result => {
            if (result.status === 'completed') {
              document.getElementById('checkoutStep1').style.display = 'none';
              document.getElementById('checkoutStep2').style.display = 'block';
              document.getElementById('licenseDisplay').textContent = result.license_key;
            } else {
              alert('支付验证失败，请联系 support@privacygw.com');
            }
          })
          .catch(err => {
            console.error('Payment completion error:', err);
            alert('网络错误，请稍后重试。如果已扣款，请联系 support@privacygw.com');
          });
        },
        onError: function(err) {
          console.error('PayPal error:', err);
          alert('PayPal 支付出错，请重试或选择其他支付方式');
        }
      }).render('#paypal-button-container');
    }

    function createWechatPayment() {
      const email = document.getElementById('customerEmail').value.trim();
      if (!email) {
        document.getElementById('wechatQrCode').innerHTML = '<div class="qr-error">请先输入邮箱地址</div>';
        return;
      }
      document.getElementById('wechatQrCode').innerHTML = '<div class="qr-loading"><div class="spinner"></div><p>正在生成支付二维码...</p></div>';
      document.getElementById('wechatStatus').innerHTML = '<span>等待支付...</span>';

      fetch(`${LICENSE_SERVER}/api/payment/wechat/create`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ customer_email: email, tier: selectedTier, expires_in_days: 365, max_concurrent: 20, amount: 99.0 })
      })
      .then(r => r.json())
      .then(result => {
        if (result.status === 'created') {
          currentOrderId = result.order_id;
          document.getElementById('wechatQrCode').innerHTML = `<img src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=${encodeURIComponent(result.qr_code_url)}" alt="微信支付二维码" width="220" height="220" />`;
          startPaymentPolling('wechat');
        } else {
          document.getElementById('wechatQrCode').innerHTML = '<div class="qr-error">生成二维码失败，请重试</div>';
        }
      })
      .catch(err => {
        console.error('WeChat payment create error:', err);
        document.getElementById('wechatQrCode').innerHTML = '<div class="qr-error">网络错误，请重试</div>';
      });
    }

    function refreshWechatQr() { createWechatPayment(); }

    function createAlipayPayment() {
      const email = document.getElementById('customerEmail').value.trim();
      if (!email) {
        document.getElementById('alipayQrCode').innerHTML = '<div class="qr-error">请先输入邮箱地址</div>';
        return;
      }
      document.getElementById('alipayQrCode').innerHTML = '<div class="qr-loading"><div class="spinner"></div><p>正在生成支付二维码...</p></div>';
      document.getElementById('alipayStatus').innerHTML = '<span>等待支付...</span>';

      fetch(`${LICENSE_SERVER}/api/payment/alipay/create`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ customer_email: email, tier: selectedTier, expires_in_days: 365, max_concurrent: 20, amount: 99.0 })
      })
      .then(r => r.json())
      .then(result => {
        if (result.status === 'created') {
          currentOrderId = result.order_id;
          document.getElementById('alipayQrCode').innerHTML = `<img src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=${encodeURIComponent(result.qr_code_url)}" alt="支付宝支付二维码" width="220" height="220" />`;
          startPaymentPolling('alipay');
        } else {
          document.getElementById('alipayQrCode').innerHTML = '<div class="qr-error">生成二维码失败，请重试</div>';
        }
      })
      .catch(err => {
        console.error('Alipay payment create error:', err);
        document.getElementById('alipayQrCode').innerHTML = '<div class="qr-error">网络错误，请重试</div>';
      });
    }

    function refreshAlipayQr() { createAlipayPayment(); }

    function startPaymentPolling(method) {
      stopPaymentPolling();
      const statusElement = document.getElementById(method === 'wechat' ? 'wechatStatus' : 'alipayStatus');
      const email = document.getElementById('customerEmail').value.trim();

      paymentPollInterval = setInterval(() => {
        fetch(`${LICENSE_SERVER}/api/payment/${method}/query`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ order_id: currentOrderId, customer_email: email })
        })
        .then(r => r.json())
        .then(result => {
          if (result.status === 'completed') {
            stopPaymentPolling();
            statusElement.innerHTML = '<span>✅ 支付成功！</span>';
            document.getElementById('checkoutStep1').style.display = 'none';
            document.getElementById('checkoutStep2').style.display = 'block';
            document.getElementById('licenseDisplay').textContent = result.license_key;
          } else if (result.status === 'not_found') {
            stopPaymentPolling();
            statusElement.innerHTML = '<span>❌ 订单不存在</span>';
          }
        })
        .catch(err => { console.error('Payment polling error:', err); });
      }, 3000);
    }

    function stopPaymentPolling() {
      if (paymentPollInterval) { clearInterval(paymentPollInterval); paymentPollInterval = null; }
    }

    document.getElementById('customerEmail').addEventListener('input', function() {
      if (selectedPayment === 'wechat') createWechatPayment();
      else if (selectedPayment === 'alipay') createAlipayPayment();
    });

    document.getElementById('checkoutOverlay').addEventListener('click', function(e) {
      if (e.target === this) closeCheckout();
    });
  </script>
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 10rem 0 4rem;
    position: relative;
  }

  .hero-content {
    text-align: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg-surface);
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--primary);
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    background: var(--primary);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-bottom: 1.5rem;
    line-height: 1.15;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.8;
    max-width: 560px;
    margin: 0 auto;
  }

  /* Pricing */
  .pricing-section {
    padding: 4rem 0 6rem;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 1200px;
  }

  .pricing-card {
    padding: 2.5rem;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .pricing-card.popular {
    border-color: var(--primary);
    box-shadow: 0 0 60px var(--primary-glow);
    transform: scale(1.03);
    background: rgba(134, 239, 172, 0.03);
    backdrop-filter: blur(24px);
    z-index: 1;
  }

  .popular-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, var(--primary-dim), var(--primary));
    color: var(--bg-deep);
    padding: 0.35rem 1.25rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .tier-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .pricing-card h2 {
    font-size: 1.75rem;
    margin-bottom: 1.25rem;
  }

  .pricing-price {
    margin-bottom: 0.5rem;
  }

  .pricing-price .price {
    font-size: 3rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .pricing-price .period {
    font-size: 1rem;
    color: var(--text-muted);
    margin-left: 0.25rem;
  }

  .pricing-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .pricing-features {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    flex: 1;
  }

  .feature-item {
    display: flex;
    align-items: center;
    padding: 0.65rem 0;
    font-size: 0.9rem;
    color: var(--text-secondary);
    gap: 0.75rem;
  }

  .feature-item.disabled {
    opacity: 0.4;
    text-decoration: line-through;
  }

  .check {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
