---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { t } from '../i18n/translations';
import { getLangFromURL } from '../i18n/utils';

const lang = getLangFromURL(Astro.url.pathname);
---

<Layout
  title={t(lang, 'pricing.title')}
  description={t(lang, 'pricing.subtitle')}
  canonicalURL="https://privacygw.pages.dev/pricing">
  <Nav />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-orb-1"></div>
    <div class="hero-orb-2"></div>
    <div class="container hero-content">
      <div class="hero-badge">
        <span class="pulse-dot"></span>
        <span>{t(lang, 'pricing.badge')}</span>
      </div>
      <h1 class="hero-title">
        {t(lang, 'pricing.hero_title1')}<br/>
        <span class="gradient-text">{t(lang, 'pricing.hero_title2')}</span>
      </h1>
      <p class="hero-desc">{t(lang, 'pricing.hero_desc')}</p>
    </div>
  </section>

  <!-- Pricing cards -->
  <section class="pricing">
    <div class="container">
      <div class="pricing-grid">
        <!-- Lite / OSS Card -->
        <div class="pricing-card pricing-featured glass glow-hover">
          <div class="pricing-glow"></div>
          <div class="pricing-badge">{t(lang, 'pricing.lite_badge')}</div>
          <div class="pricing-header">
            <h2 class="pricing-name">{t(lang, 'pricing.lite_name')}</h2>
            <div class="pricing-amount">
              <span class="pricing-currency">$</span>
              <span class="pricing-value">{t(lang, 'pricing.lite_price')}</span>
            </div>
            <p class="pricing-period">{t(lang, 'pricing.lite_period')}</p>
          </div>

          <ul class="pricing-features">
            <li class="pricing-feat">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {t(lang, 'pricing.lite_feature1')}
            </li>
            <li class="pricing-feat">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {t(lang, 'pricing.lite_feature2')}
            </li>
            <li class="pricing-feat">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {t(lang, 'pricing.lite_feature3')}
            </li>
            <li class="pricing-feat">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {t(lang, 'pricing.lite_feature4')}
            </li>
            <li class="pricing-feat">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {t(lang, 'pricing.lite_feature5')}
            </li>
            <li class="pricing-feat">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {t(lang, 'pricing.lite_feature6')}
            </li>
            <li class="pricing-feat">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {t(lang, 'pricing.lite_feature7')}
            </li>
            <li class="pricing-feat">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {t(lang, 'pricing.lite_feature8')}
            </li>
          </ul>

          <a href="/download" class="btn btn-primary pricing-cta">
            {t(lang, 'pricing.lite_cta')}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>

          <p class="pricing-footnote">{t(lang, 'pricing.lite_footnote')}</p>
        </div>

        <!-- Enterprise -->
        <div class="pricing-card glass">
          <div class="pricing-badge pricing-badge-soon">{t(lang, 'pricing.ent_badge')}</div>
          <div class="pricing-header">
            <h2 class="pricing-name">{t(lang, 'pricing.ent_name')}</h2>
            <p class="pricing-period" style="margin-top:0.75rem;">{t(lang, 'pricing.ent_desc')}</p>
          </div>

          <ul class="pricing-features">
            <li class="pricing-feat">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {t(lang, 'pricing.ent_feature1')}
            </li>
            <li class="pricing-feat">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {t(lang, 'pricing.ent_feature2')}
            </li>
            <li class="pricing-feat">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {t(lang, 'pricing.ent_feature3')}
            </li>
            <li class="pricing-feat">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {t(lang, 'pricing.ent_feature4')}
            </li>
            <li class="pricing-feat">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {t(lang, 'pricing.ent_feature5')}
            </li>
          </ul>

          <a href="https://t.me/chirstmas_7" class="btn btn-ghost pricing-cta">
            {t(lang, 'pricing.ent_cta')}
          </a>
          <p class="pricing-footnote">{t(lang, 'pricing.ent_footnote')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature comparison -->
  <section class="comparison">
    <div class="container">
      <h2 class="section-title">{t(lang, 'pricing.comp_title')}</h2>
      <p class="section-subtitle">{t(lang, 'pricing.comp_subtitle')}</p>

      <div class="comparison-table-wrap glass">
        <table class="comparison-table">
          <thead>
            <tr>
              <th class="comp-feat-th">{t(lang, 'pricing.comp_feature_col')}</th>
              <th class="comp-tier-th comp-lite">{t(lang, 'pricing.comp_lite_col')}</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="comp-feat">{t(lang, 'pricing.comp_f1')}</td>
              <td class="comp-cell"><span class="check">&#10003;</span></td>
            </tr>
            <tr>
              <td class="comp-feat">{t(lang, 'pricing.comp_f2')}</td>
              <td class="comp-cell"><span class="check">&#10003;</span></td>
            </tr>
            <tr>
              <td class="comp-feat">{t(lang, 'pricing.comp_f3')}</td>
              <td class="comp-cell"><span class="check">&#10003;</span></td>
            </tr>
            <tr>
              <td class="comp-feat">{t(lang, 'pricing.comp_f4')}</td>
              <td class="comp-cell"><span class="check">&#10003;</span></td>
            </tr>
            <tr>
              <td class="comp-feat">{t(lang, 'pricing.comp_f5')}</td>
              <td class="comp-cell"><span class="check">&#10003;</span></td>
            </tr>
            <tr>
              <td class="comp-feat">{t(lang, 'pricing.comp_f6')}</td>
              <td class="comp-cell"><span class="check">&#10003;</span></td>
            </tr>
            <tr>
              <td class="comp-feat">{t(lang, 'pricing.comp_f7')}</td>
              <td class="comp-cell"><span class="check">&#10003;</span></td>
            </tr>
            <tr>
              <td class="comp-feat">{t(lang, 'pricing.comp_f8')}</td>
              <td class="comp-cell"><span class="check">&#10003;</span></td>
            </tr>
            <tr>
              <td class="comp-feat">{t(lang, 'pricing.comp_f9')}</td>
              <td class="comp-cell"><span class="check">&#10003;</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Trust / Open Source Callout -->
  <section class="trust">
    <div class="container">
      <div class="trust-card glass">
        <div class="trust-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <h3>{t(lang, 'pricing.trust_title')}</h3>
        <p>{t(lang, 'pricing.trust_desc')}</p>
        <div class="trust-buttons">
          <a href="https://github.com/gunxueqiu6/ai-privacy-gateway" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            {t(lang, 'pricing.trust_source')}
          </a>
          <a href="/download" class="btn btn-ghost">{t(lang, 'pricing.trust_download')}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq">
    <div class="container">
      <h2 class="section-title">{t(lang, 'pricing.faq_title')}</h2>
      <div class="faq-grid">
        <div class="faq-item glass">
          <h3>{t(lang, 'pricing.faq_q1')}</h3>
          <p>{t(lang, 'pricing.faq_a1')}</p>
        </div>
        <div class="faq-item glass">
          <h3>{t(lang, 'pricing.faq_q2')}</h3>
          <p>{t(lang, 'pricing.faq_a2')}</p>
        </div>
        <div class="faq-item glass">
          <h3>{t(lang, 'pricing.faq_q3')}</h3>
          <p>{t(lang, 'pricing.faq_a3')}</p>
        </div>
        <div class="faq-item glass">
          <h3>{t(lang, 'pricing.faq_q4')}</h3>
          <p set:html={t(lang, 'pricing.faq_a4')} />
        </div>
        <div class="faq-item glass">
          <h3>{t(lang, 'pricing.faq_q5')}</h3>
          <p set:html={t(lang, 'pricing.faq_a5')} />
        </div>
        <div class="faq-item glass">
          <h3>{t(lang, 'pricing.faq_q6')}</h3>
          <p set:html={t(lang, 'pricing.faq_a6')} />
        </div>
      </div>
    </div>
  </section>

  <Footer />

  <style>
    /* --- Hero --- */
    .hero {
      padding: 10rem 0 4rem;
      position: relative;
      overflow: hidden;
    }

    .hero-orb-1 {
      position: absolute; top: -200px; right: -100px;
      width: 650px; height: 650px;
      background: radial-gradient(circle, var(--primary-glow) 0%, rgba(134, 239, 172, 0.05) 40%, transparent 60%);
      border-radius: 50%; filter: blur(100px);
      animation: orb-f 18s ease-in-out infinite;
      pointer-events: none;
    }

    .hero-orb-2 {
      position: absolute; bottom: -150px; left: -100px;
      width: 500px; height: 500px;
      background: radial-gradient(circle, var(--accent-glow) 0%, rgba(167, 139, 250, 0.05) 40%, transparent 60%);
      border-radius: 50%; filter: blur(80px);
      animation: orb-f 22s ease-in-out infinite -7s;
      pointer-events: none;
    }

    @keyframes orb-f {
      0%, 100% { transform: translateY(0) scale(1); }
      50% { transform: translateY(-20px) scale(1.05); }
    }

    .hero-content { text-align: center; position: relative; z-index: 1; }

    .hero-badge {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: var(--glass-bg); backdrop-filter: var(--glass-blur);
      padding: 0.5rem 1rem; border-radius: 20px;
      font-size: 0.85rem; color: var(--primary); margin-bottom: 1.5rem;
      border: 1px solid var(--border);
    }

    .hero-title {
      font-size: 3.5rem; font-weight: 700; letter-spacing: -0.04em;
      margin-bottom: 1.25rem; line-height: 1.15;
    }

    .hero-desc {
      font-size: 1.1rem; color: var(--text-secondary);
      max-width: 540px; margin: 0 auto; line-height: 1.8;
    }

    /* --- Pricing Cards --- */
    .pricing { padding: 4rem 0; position: relative; z-index: 1; }

    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
      max-width: 800px;
      margin: 0 auto;
      align-items: start;
    }

    .pricing-card {
      padding: 2.5rem 2rem;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
    }

    .pricing-featured {
      position: relative;
      border-color: rgba(134, 239, 172, 0.2);
    }

    .pricing-glow {
      position: absolute;
      top: -50%;
      left: 50%;
      transform: translateX(-50%);
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(134, 239, 172, 0.08), transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }

    .pricing-badge {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 0.3rem 0.75rem;
      border-radius: 6px;
      background: rgba(74, 222, 128, 0.12);
      color: #4ade80;
      margin-bottom: 1.5rem;
      align-self: flex-start;
    }

    .pricing-badge-soon {
      background: rgba(148, 163, 184, 0.1);
      color: var(--text-muted);
    }

    .pricing-header { margin-bottom: 2rem; }

    .pricing-name {
      font-size: 1.15rem;
      margin-bottom: 0.75rem;
    }

    .pricing-amount {
      display: flex;
      align-items: baseline;
      gap: 0.15rem;
      margin-bottom: 0.35rem;
    }

    .pricing-currency {
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--text-secondary);
    }

    .pricing-value {
      font-size: 3rem;
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1;
    }

    .pricing-featured .pricing-value {
      background: linear-gradient(135deg, var(--primary), var(--cyan));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .pricing-unit {
      font-size: 1rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    .pricing-period {
      font-size: 0.82rem;
      color: var(--text-muted);
    }

    .pricing-features {
      list-style: none;
      padding: 0;
      margin: 0 0 2rem;
      flex: 1;
    }

    .pricing-feat {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.5rem 0;
      font-size: 0.88rem;
      color: var(--text-secondary);
    }

    .pricing-feat svg {
      flex-shrink: 0;
      color: var(--primary);
    }

    .pricing-cta {
      width: 100%;
      padding: 0.85rem;
      font-size: 1rem;
      text-align: center;
      box-sizing: border-box;
    }

    .pricing-cta-disabled {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0.85rem;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid var(--border);
      color: var(--text-muted);
      font-weight: 600;
      font-size: 1rem;
    }

    .pricing-footnote {
      font-size: 0.78rem;
      color: var(--text-muted);
      text-align: center;
      margin-top: 0.75rem;
    }

    /* --- Comparison Table --- */
    .comparison { padding: 4rem 0 6rem; position: relative; z-index: 1; }

    .comparison-table-wrap {
      max-width: 800px;
      margin: 0 auto;
      padding: 0;
      overflow: hidden;
    }

    .comparison-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.88rem;
    }

    .comparison-table th,
    .comparison-table td {
      padding: 0.85rem 1rem;
      text-align: center;
      border-bottom: 1px solid var(--border);
    }

    .comp-feat-th {
      text-align: left;
      color: var(--text-muted);
      font-weight: 600;
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .comp-tier-th {
      font-weight: 700;
      font-size: 0.85rem;
      white-space: nowrap;
    }

    .comp-lite { color: #4ade80; }
    .comp-pro { color: var(--accent); }
    .comp-ent { color: var(--warning); }

    .comp-feat {
      text-align: left;
      color: var(--text-secondary);
      font-size: 0.85rem;
    }

    .comp-cell {
      color: var(--text-primary);
      font-size: 0.88rem;
    }

    .check { color: var(--primary); font-weight: 700; }
    .cross { color: var(--text-dim); }

    /* --- Trust --- */
    .trust { padding: 2rem 0 6rem; position: relative; z-index: 1; }

    .trust-card {
      max-width: 600px;
      margin: 0 auto;
      padding: 3rem 2.5rem;
      text-align: center;
    }

    .trust-icon {
      display: flex;
      justify-content: center;
      margin-bottom: 1.25rem;
      color: var(--primary);
    }

    .trust-card h3 {
      font-size: 1.3rem;
      margin-bottom: 0.75rem;
    }

    .trust-card p {
      color: var(--text-secondary);
      font-size: 0.92rem;
      line-height: 1.7;
      margin-bottom: 1.5rem;
    }

    .trust-buttons {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
    }

    /* --- FAQ --- */
    .faq { padding: 0 0 6rem; position: relative; z-index: 1; }

    .faq-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
      max-width: 900px;
      margin: 0 auto;
    }

    .faq-item {
      padding: 1.5rem;
    }

    .faq-item h3 {
      color: var(--primary);
      margin-bottom: 0.5rem;
      font-size: 1rem;
    }

    .faq-item p {
      color: var(--text-secondary);
      font-size: 0.88rem;
      line-height: 1.7;
    }

    .faq-item code {
      background: var(--bg-deep);
      padding: 0.1rem 0.4rem;
      border-radius: 4px;
      font-size: 0.82rem;
      color: var(--primary);
    }

    .faq-item a { color: var(--primary); }

    /* --- Responsive --- */
    @media (min-width: 1440px) and (max-width: 1919px) {
      .hero-title { font-size: 4rem; }
    }

    @media (min-width: 1024px) and (max-width: 1279px) {
      .hero-title { font-size: 3rem; }
    }

    @media (min-width: 768px) and (max-width: 1023px) {
      .hero { padding: 8rem 0 3rem; }
      .hero-title { font-size: 2.75rem; }
      .pricing-grid { grid-template-columns: 1fr; max-width: 450px; }
      .faq-grid { grid-template-columns: 1fr; max-width: 550px; }
    }

    @media (max-width: 767px) {
      .hero { padding: 7rem 0 3rem; }
      .hero-title { font-size: 2.25rem; }
      .hero-desc { font-size: 1rem; }
      .pricing-grid { grid-template-columns: 1fr; max-width: 400px; }
      .pricing-card { padding: 2rem 1.5rem; }
      .faq-grid { grid-template-columns: 1fr; }
      .trust-card { padding: 2rem 1.5rem; }
      .trust-buttons { flex-direction: column; }
      .comparison-table { font-size: 0.78rem; }
      .comparison-table th,
      .comparison-table td { padding: 0.65rem 0.5rem; }
      .hero-orb-1 { width: 350px; height: 350px; top: -50px; right: -80px; opacity: 0.3; }
      .hero-orb-2 { width: 300px; height: 300px; opacity: 0.3; }
    }

    @media (max-width: 639px) {
      .hero-title { font-size: 2rem; }
      .pricing-grid { max-width: 100%; }
    }
  </style>
</Layout>
