---
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import roles, { type Role } from '../../data/roles';

export const getStaticPaths: GetStaticPaths = () => {
  return roles.map((r) => ({
    params: { role: r.slug },
    props: { role: r },
  }));
};

const { role } = Astro.props as { role: Role };
const pageUrl = `https://privacygw.pages.dev/for/${role.slug}`;
---

<Layout
  title={`AI Data Privacy for ${role.title} — ${role.primaryKeyword}`}
  description={`${role.subtitle} Learn how AI Privacy Gateway helps ${role.title.toLowerCase()}s protect sensitive data across all AI APIs with zero code changes.`}
  keywords={`${role.title} AI数据安全,${role.primaryKeyword},AI隐私保护方案,企业AI安全,数据隐私`}
  canonicalURL={pageUrl}
  ogType="article"
  hreflang={[
    { lang: 'zh-CN', url: pageUrl },
    { lang: 'x-default', url: pageUrl },
  ]}>
  <Nav />

  <section class="seo-page">
    <div class="container">
      <div class="seo-header">
        <div class="seo-badge">For {role.title}s</div>
        <h1>AI Data Privacy for {role.title}s</h1>
        <p class="seo-subtitle">{role.subtitle}</p>
      </div>

      <div class="seo-tldr glass">
        <strong>TL;DR:</strong> AI Privacy Gateway gives {role.title.toLowerCase()}s a single, open-source privacy proxy that masks PII in all AI API calls — deployed in 30 seconds with zero code changes across any AI provider.
      </div>

      <h2>Key Challenges {role.title}s Face with AI Adoption</h2>
      <div class="challenge-grid">
        {role.painPoints.map((pp, i) => (
          <div class="challenge-card glass">
            <div class="challenge-num">{i + 1}</div>
            <h3>{pp.title}</h3>
            <p>{pp.description}</p>
          </div>
        ))}
      </div>

      <h2>How AI Privacy Gateway Addresses These Challenges</h2>
      <div class="benefit-grid">
        {role.benefits.map((b, i) => (
          <div class="benefit-card glass">
            <div class="benefit-icon">&#10003;</div>
            <div class="benefit-text">{b}</div>
          </div>
        ))}
      </div>

      <h2>Why {role.title}s Trust AI Privacy Gateway</h2>
      <div class="challenge-grid">
        <div class="challenge-card glass">
          <div class="challenge-num">1</div>
          <h3>Deploy in 30 Seconds</h3>
          <p>Single Docker container. No code changes. No architecture overhaul. Just change the API base URL and your data is protected.</p>
        </div>
        <div class="challenge-card glass">
          <div class="challenge-num">2</div>
          <h3>100% Local Processing</h3>
          <p>All PII masking happens on your infrastructure. No data ever leaves your network for processing. This is the foundation of GDPR, HIPAA, and PIPL compliance.</p>
        </div>
        <div class="challenge-card glass">
          <div class="challenge-num">3</div>
          <h3>MIT Open Source</h3>
          <p>Full source code available. No vendor lock-in. No per-seat pricing. No usage limits. Deploy in any environment, audit every line of code.</p>
        </div>
        <div class="challenge-card glass">
          <div class="challenge-num">4</div>
          <h3>Universal AI Coverage</h3>
          <p>Works with every AI provider through a single proxy — OpenAI, Anthropic, DeepSeek, Cursor, Claude Code, LangChain, and any OpenAI-compatible API.</p>
        </div>
      </div>

      <!-- CTA -->
      <div class="seo-cta">
        <h2>Protect Your Organization's AI Data Today</h2>
        <p>Deploy in 30 seconds. Open source. Zero trust.</p>
        <div class="seo-cta-buttons">
          <a href="/download" class="btn btn-primary btn-lg">Get Started Free</a>
          <a href="/demo" class="btn btn-ghost btn-lg">Live Demo</a>
        </div>
      </div>

      <!-- FAQ -->
      <div class="seo-faq glass">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
          <h3>How does this help with compliance audits?</h3>
          <p>AI Privacy Gateway provides detailed audit logs of every masking event, showing what data was detected and masked before reaching AI providers. This serves as technical evidence for SOC 2, ISO 27001, GDPR, and HIPAA audits.</p>
        </div>
        <div class="faq-item">
          <h3>Can it integrate with our existing security stack?</h3>
          <p>Yes. The gateway is a lightweight Docker container that fits into any infrastructure. It exposes health check endpoints, structured logging, and can be monitored alongside your existing services.</p>
        </div>
        <div class="faq-item">
          <h3>What is the performance impact?</h3>
          <p>Less than 1ms per request. The detection engine is written in Rust for maximum performance, and all processing happens locally with no external API calls.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .seo-page { padding: 8rem 0 4rem; }
  .seo-page .container { max-width: 820px; margin: 0 auto; }
  .seo-header { margin-bottom: 3rem; }
  .seo-badge {
    display: inline-block; padding: 0.35rem 0.85rem; border-radius: 20px;
    font-size: 0.78rem; font-weight: 600; color: var(--primary);
    background: rgba(134, 239, 172, 0.08); border: 1px solid rgba(134, 239, 172, 0.15);
    margin-bottom: 1.25rem;
  }
  .seo-page h1 { font-size: 2.75rem; font-weight: 800; letter-spacing: -0.04em; line-height: 1.15; margin-bottom: 1.25rem; }
  .seo-subtitle { font-size: 1.1rem; color: var(--text-secondary); line-height: 1.8; }
  .seo-tldr { padding: 1.25rem 1.5rem; margin-bottom: 2.5rem; font-size: 0.95rem; line-height: 1.7; color: var(--text-primary); }
  .seo-tldr strong { color: var(--primary); }
  .seo-page h2 { font-size: 1.8rem; font-weight: 700; letter-spacing: -0.03em; margin: 3rem 0 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border); }
  .seo-page h3 { font-size: 1.25rem; font-weight: 600; margin: 2rem 0 0.75rem; }
  .seo-page p { color: var(--text-secondary); line-height: 1.8; margin-bottom: 1.25rem; }

  .challenge-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 2.5rem; }
  .challenge-card { padding: 1.75rem; }
  .challenge-num { font-size: 2rem; font-weight: 800; color: var(--primary); opacity: 0.5; margin-bottom: 0.5rem; line-height: 1; }
  .challenge-card h3 { margin: 0 0 0.5rem; font-size: 1.05rem; }
  .challenge-card p { margin: 0; font-size: 0.88rem; line-height: 1.7; }

  .benefit-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 2.5rem; }
  .benefit-card { display: flex; align-items: flex-start; gap: 0.75rem; padding: 1rem 1.25rem; }
  .benefit-icon { color: var(--primary); font-weight: 700; font-size: 1rem; flex-shrink: 0; margin-top: 0.1rem; }
  .benefit-text { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.6; }

  .seo-faq { padding: 2rem; margin-bottom: 3rem; }
  .seo-faq h2 { border: none; margin-top: 0; }
  .faq-item { padding: 1rem 0; border-bottom: 1px solid var(--border); }
  .faq-item:last-child { border: none; }
  .faq-item h3 { margin: 0 0 0.5rem; font-size: 1.05rem; color: var(--text-primary); }
  .faq-item p { margin: 0; font-size: 0.92rem; }

  .seo-cta { text-align: center; padding: 3rem 2rem; background: var(--glass-bg); border: 1px solid var(--border); border-radius: 20px; margin-top: 3rem; }
  .seo-cta h2 { margin-top: 0; border: none; }
  .seo-cta p { color: var(--text-secondary); margin-bottom: 1.5rem; }
  .seo-cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 768px) {
    .seo-page { padding: 6rem 0 3rem; }
    .seo-page h1 { font-size: 2rem; }
    .seo-page h2 { font-size: 1.4rem; }
    .challenge-grid, .benefit-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 639px) {
    .seo-page h1 { font-size: 1.75rem; }
    .seo-cta-buttons { flex-direction: column; }
    .seo-cta-buttons .btn { width: 100%; }
  }
</style>
