---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="在线 Demo — AI Privacy Gateway | 实时脱敏演示"
  description="AI Privacy Gateway 在线演示：输入文本，实时查看脱敏效果，支持手机号、邮箱、身份证、银行卡、人名、地名等 13 种实体类型检测。"
  canonicalURL="https://privacygw.pages.dev/demo">
  <Nav />

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        <span>交互式演示</span>
      </div>
      <h1 class="hero-title">
        实时<span class="gradient-text">脱敏</span>演示
      </h1>
      <p class="hero-description">
        输入任意包含敏感数据的文本，实时查看 AI Privacy Gateway 的检测和脱敏效果。
        支持 13 种实体类型，本地处理，数据不上传。
      </p>
    </div>
  </section>

  <!-- Demo Area -->
  <section class="demo-section">
    <div class="container">
      <div class="demo-grid">
        <!-- Input -->
        <div class="demo-panel glass">
          <div class="panel-header">
            <h3>原始文本</h3>
            <span class="panel-badge">输入</span>
          </div>
          <textarea
            id="inputText"
            class="demo-textarea"
            placeholder="请输入需要脱敏的文本...&#10;&#10;例如：&#10;张三住在北京市海淀区，电话13812345678，邮箱test@example.com，身份证号110101199001011234"></textarea>
          <div class="panel-actions">
            <button class="btn btn-secondary btn-sm" onclick="loadExample()">加载示例</button>
            <button class="btn btn-secondary btn-sm" onclick="clearText()">清空</button>
          </div>
          <button class="btn btn-primary btn-full" onclick="processText()">开始脱敏</button>
        </div>

        <!-- Output -->
        <div class="demo-panel glass">
          <div class="panel-header">
            <h3>脱敏结果</h3>
            <span class="panel-badge">输出</span>
          </div>
          <div class="demo-output" id="outputText">
            <div class="output-placeholder">
              <div class="placeholder-icon">&#9679;</div>
              <p>脱敏结果将在此显示</p>
            </div>
          </div>
          <div class="output-stats" id="outputStats"></div>
        </div>
      </div>

      <!-- Legend -->
      <div class="legend glass">
        <h4>实体类型图例</h4>
        <div class="legend-tags">
          <span class="legend-tag tag-phone">手机号</span>
          <span class="legend-tag tag-email">邮箱</span>
          <span class="legend-tag tag-idcard">身份证</span>
          <span class="legend-tag tag-bank">银行卡</span>
          <span class="legend-tag tag-person">人名</span>
          <span class="legend-tag tag-location">地名</span>
          <span class="legend-tag tag-org">机构</span>
        </div>
      </div>

      <!-- Entities Table -->
      <div class="entities-panel glass" id="entitiesPanel" style="display: none;">
        <h4>检测到的敏感实体</h4>
        <div class="entities-table-wrap">
          <table class="entities-table">
            <thead>
              <tr><th>类型</th><th>原始值</th><th>占位符</th><th>位置</th></tr>
            </thead>
            <tbody id="entitiesBody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <Footer />

  <script is:inline>
    const API_ENDPOINT = 'http://localhost:9999/api/mask';
    let isProcessing = false;

    function loadExample() {
      document.getElementById('inputText').value = `张三住在北京市海淀区中关村大街1号，联系电话13812345678，邮箱test@example.com。\n身份证号：110101199001011234，银行卡号：6222021234567890123。\n公司名称：北京科技有限公司，车牌号：京A12345，IP地址：192.168.1.100。\n今天是2024年1月15日，转账金额¥999.99，邮编100080。`;
    }

    function clearText() {
      document.getElementById('inputText').value = '';
      document.getElementById('outputText').innerHTML = '<div class="output-placeholder"><div class="placeholder-icon">&#9679;</div><p>脱敏结果将在此显示</p></div>';
      document.getElementById('outputStats').innerHTML = '';
      document.getElementById('entitiesPanel').style.display = 'none';
    }

    async function processText() {
      const input = document.getElementById('inputText').value.trim();
      if (!input) { alert('请输入需要脱敏的文本'); return; }
      if (isProcessing) return;
      isProcessing = true;

      const outputDiv = document.getElementById('outputText');
      outputDiv.innerHTML = '<div class="processing-indicator"><div class="spinner"></div><p>正在检测敏感数据...</p></div>';
      document.getElementById('outputStats').innerHTML = '';
      document.getElementById('entitiesPanel').style.display = 'none';

      try {
        const response = await fetch(API_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text: input })
        });
        const result = await response.json();
        displayResult(result);
      } catch (error) {
        outputDiv.innerHTML = '<div class="error-message"><p>请求失败，请确保本地网关已启动 (http://localhost:9999)</p></div>';
        console.error('API Error:', error);
      } finally {
        isProcessing = false;
      }
    }

    function displayResult(result) {
      const outputDiv = document.getElementById('outputText');
      const statsDiv = document.getElementById('outputStats');
      const entitiesPanel = document.getElementById('entitiesPanel');
      const entitiesBody = document.getElementById('entitiesBody');

      const tagMap = {
        'PII_PHONE': 'tag-phone', 'PII_EMAIL': 'tag-email', 'PII_IDCARD': 'tag-idcard',
        'PII_BANK': 'tag-bank', 'PII_PER': 'tag-person', 'PII_LOC': 'tag-location',
        'PII_ORG': 'tag-org', 'PII_PLATE': 'tag-org', 'PII_IP': 'tag-email',
        'PII_URL': 'tag-phone', 'PII_DATE': 'tag-idcard', 'PII_AMOUNT': 'tag-bank',
        'PII_POSTCODE': 'tag-location', 'PII_CUST': 'tag-person',
      };

      const typeNames = {
        'PII_PHONE': '手机号', 'PII_EMAIL': '邮箱', 'PII_IDCARD': '身份证',
        'PII_BANK': '银行卡', 'PII_PER': '人名', 'PII_LOC': '地名',
        'PII_ORG': '机构', 'PII_PLATE': '车牌号', 'PII_IP': 'IP地址',
        'PII_URL': 'URL', 'PII_DATE': '日期', 'PII_AMOUNT': '金额',
        'PII_POSTCODE': '邮编', 'PII_CUST': '自定义'
      };

      let html = escapeHtml(result.masked_text);
      result.entities.forEach(entity => {
        const tag = tagMap[entity.type] || 'tag-org';
        html = html.replace(new RegExp(escapeRegex(escapeHtml(entity.placeholder)), 'g'),
          `<mark class="${tag}">${escapeHtml(entity.placeholder)}</mark>`);
      });
      outputDiv.innerHTML = `<pre class="output-content">${html}</pre>`;

      const totalMasked = Object.values(result.stats || {}).reduce((s, v) => s + (v || 0), 0);
      statsDiv.innerHTML = `<div class="stats-row"><div class="stat-item"><span class="stat-value">${totalMasked}</span><span class="stat-label">检测到的实体</span></div><div class="stat-item"><span class="stat-value">${result.entities.length}</span><span class="stat-label">脱敏替换数</span></div></div>`;

      if (result.entities && result.entities.length > 0) {
        entitiesPanel.style.display = 'block';
        entitiesBody.innerHTML = result.entities.map(e => `
          <tr>
            <td><span class="entity-tag ${tagMap[e.type] || 'tag-org'}">${typeNames[e.type] || e.type}</span></td>
            <td class="entity-value">${escapeHtml(e.value)}</td>
            <td class="entity-placeholder">${escapeHtml(e.placeholder)}</td>
            <td>${e.position}</td>
          </tr>`).join('');
      }
    }

    function escapeHtml(text) { const d = document.createElement('div'); d.textContent = text; return d.innerHTML; }
    function escapeRegex(text) { return text.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }

    loadExample();
  </script>

  <style>
    .hero {
      padding: 10rem 0 4rem;
      position: relative;
    }
    .hero-content { text-align: center; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: var(--bg-surface); padding: 0.5rem 1rem; border-radius: 20px;
      font-size: 0.875rem; font-weight: 500; color: var(--primary); margin-bottom: 1.5rem;
    }
    .badge-dot { width: 8px; height: 8px; background: var(--primary); border-radius: 50%; animation: pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
    .hero-title { font-size: 3.5rem; font-weight: 700; letter-spacing: -0.04em; margin-bottom: 1.5rem; line-height: 1.15; }
    .gradient-text {
      background: linear-gradient(135deg, var(--primary), var(--accent));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .hero-description { font-size: 1.125rem; color: var(--text-secondary); line-height: 1.8; max-width: 600px; margin: 0 auto; }

    .demo-section { padding: 4rem 0 6rem; }
    .demo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; max-width: 1200px; margin: 0 auto 2rem; }
    .demo-panel { padding: 1.5rem; display: flex; flex-direction: column; }
    .panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
    .panel-header h3 { margin: 0; color: var(--primary); font-size: 1.1rem; }
    .panel-badge {
      font-size: 0.7rem; padding: 0.2rem 0.75rem; border-radius: 20px;
      background: rgba(134, 239, 172, 0.1); color: var(--primary); font-weight: 600;
    }

    .demo-textarea {
      flex: 1; width: 100%; min-height: 240px; padding: 1rem;
      border: 1px solid var(--border); border-radius: 10px;
      background: var(--bg-deep); color: var(--text-primary);
      font-family: 'Fira Code', monospace; font-size: 0.9rem;
      resize: vertical; outline: none; transition: border-color 0.3s;
    }
    .demo-textarea:focus { border-color: var(--primary); }

    .panel-actions { display: flex; gap: 0.5rem; margin-top: 0.75rem; }
    .btn-sm { padding: 0.5rem 1rem; font-size: 0.85rem; }
    .btn-full { width: 100%; margin-top: 0.75rem; }
    .btn-secondary {
      background: var(--glass-bg); color: var(--text-primary);
      border: 1px solid var(--border-hover); backdrop-filter: var(--glass-blur);
    }
    .btn-secondary:hover { border-color: var(--primary); color: var(--primary); }

    .demo-output { flex: 1; min-height: 240px; border: 1px solid var(--border); border-radius: 10px; padding: 1rem; background: var(--bg-deep); overflow: auto; }
    .output-placeholder { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 200px; color: var(--text-muted); }
    .placeholder-icon { width: 48px; height: 48px; border-radius: 50%; background: rgba(134, 239, 172, 0.08); display: flex; align-items: center; justify-content: center; color: var(--primary); font-size: 1.2rem; margin-bottom: 1rem; }
    .output-content { white-space: pre-wrap; word-wrap: break-word; margin: 0; color: var(--text-primary); font-family: 'Fira Code', monospace; font-size: 0.9rem; line-height: 1.7; }

    .processing-indicator { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 200px; color: var(--text-muted); }
    .spinner { width: 36px; height: 36px; border: 3px solid var(--border); border-top-color: var(--primary); border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 0.75rem; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .error-message { display: flex; align-items: center; justify-content: center; height: 200px; color: var(--danger); text-align: center; padding: 1rem; }

    .output-stats { margin-top: 0.75rem; }
    .stats-row { display: flex; gap: 0.75rem; }
    .stats-row .stat-item { flex: 1; text-align: center; padding: 0.75rem; background: var(--bg-deep); border-radius: 8px; }
    .stats-row .stat-value { display: block; font-size: 1.35rem; font-weight: 700; color: var(--primary); }
    .stats-row .stat-label { display: block; font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.15rem; }

    .legend { padding: 1.25rem 1.5rem; margin-bottom: 2rem; }
    .legend h4 { margin: 0 0 0.75rem 0; color: var(--primary); font-size: 0.95rem; }
    .legend-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .legend-tag { padding: 0.3rem 0.75rem; border-radius: 20px; font-size: 0.8rem; font-weight: 500; }
    .tag-phone { background: rgba(251, 191, 36, 0.15); color: #fbbf24; }
    .tag-email { background: rgba(96, 165, 250, 0.15); color: #60a5fa; }
    .tag-idcard { background: rgba(134, 239, 172, 0.15); color: var(--primary); }
    .tag-bank { background: rgba(244, 114, 182, 0.15); color: #f472b6; }
    .tag-person { background: rgba(167, 139, 250, 0.15); color: var(--accent); }
    .tag-location { background: rgba(252, 165, 165, 0.15); color: #fca5a5; }
    .tag-org { background: rgba(148, 163, 184, 0.15); color: #94a3b8; }

    .entities-panel { padding: 1.5rem; margin-bottom: 2rem; }
    .entities-panel h4 { margin: 0 0 1rem 0; color: var(--primary); font-size: 0.95rem; }
    .entities-table-wrap { overflow-x: auto; }
    .entities-table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
    .entities-table th, .entities-table td { padding: 0.7rem 0.9rem; text-align: left; border-bottom: 1px solid var(--border); }
    .entities-table th { background: var(--bg-deep); font-weight: 600; color: var(--text-secondary); font-size: 0.8rem; }
    .entities-table tr:hover td { background: rgba(134, 239, 172, 0.03); }
    .entity-tag { padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.72rem; font-weight: 600; }
    .entity-value { font-family: 'Fira Code', monospace; color: var(--text-primary); }
    .entity-placeholder { font-family: 'Fira Code', monospace; color: var(--primary); }

    mark.tag-phone { background: rgba(251, 191, 36, 0.2); color: #fbbf24; border-radius: 3px; padding: 0 3px; }
    mark.tag-email { background: rgba(96, 165, 250, 0.2); color: #60a5fa; border-radius: 3px; padding: 0 3px; }
    mark.tag-idcard { background: rgba(134, 239, 172, 0.2); color: var(--primary); border-radius: 3px; padding: 0 3px; }
    mark.tag-bank { background: rgba(244, 114, 182, 0.2); color: #f472b6; border-radius: 3px; padding: 0 3px; }
    mark.tag-person { background: rgba(167, 139, 250, 0.2); color: var(--accent); border-radius: 3px; padding: 0 3px; }
    mark.tag-location { background: rgba(252, 165, 165, 0.2); color: #fca5a5; border-radius: 3px; padding: 0 3px; }
    mark.tag-org { background: rgba(148, 163, 184, 0.2); color: #94a3b8; border-radius: 3px; padding: 0 3px; }

    @media (max-width: 768px) {
      .hero-title { font-size: 2.25rem; }
      .demo-grid { grid-template-columns: 1fr; }
      .panel-actions { flex-direction: column; }
    }
  </style>
</Layout>
