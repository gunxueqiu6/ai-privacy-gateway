---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Online PII Detection Demo — Free AI Privacy Gateway | No Upload Required"
  description="Interactive demo: paste text containing PII and see how AI Privacy Gateway detects and masks phone numbers, emails, ID cards, bank cards, and 14+ entity types in real time. All processing stays in your browser — zero data uploaded."
  keywords="PII检测演示,数据脱敏在线测试,隐私网关演示,敏感信息检测工具,个人隐私保护演示"
  canonicalURL="https://privacygw.pages.dev/demo"
  ogType="website">
  <Nav />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-orb-1"></div>
    <div class="hero-orb-2"></div>
    <div class="container hero-content">
      <div class="hero-badge">
        <span class="pulse-dot"></span>
        <span>Interactive Demo &middot; All Processing Local</span>
      </div>
      <h1 class="hero-title">
        See it in <span class="gradient-text">action</span>
      </h1>
      <p class="hero-desc">
        Paste any text containing sensitive data below. The demo runs entirely in your browser
        &mdash; nothing is uploaded, nothing is stored.
      </p>
    </div>
  </section>

  <!-- Demo Area -->
  <section class="demo-section">
    <div class="container">
      <div class="demo-grid">
        <!-- Input Panel -->
        <div class="demo-panel glass">
          <div class="panel-head">
            <h2>
              <span class="panel-indicator input-indicator"></span>
              Raw Text
            </h2>
            <span class="panel-badge badge-input">Input</span>
          </div>
          <textarea
            id="inputText"
            class="demo-textarea"
            placeholder='Paste text containing PII...&#10;&#10;Example:&#10;张三住在北京市海淀区，电话13812345678，邮箱test@example.com，身份证号110101199001011234'></textarea>
          <div class="panel-toolbar">
            <button class="btn btn-sm btn-secondary" onclick="loadExample()">Load Example</button>
            <button class="btn btn-sm btn-secondary" onclick="clearText()">Clear</button>
          </div>
          <button class="btn btn-primary btn-full" onclick="processText()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            Mask PII
          </button>
        </div>

        <!-- Output Panel -->
        <div class="demo-panel glass">
          <div class="panel-head">
            <h2>
              <span class="panel-indicator output-indicator"></span>
              Masked Result
            </h2>
            <span class="panel-badge badge-output">Output</span>
          </div>
          <div class="demo-output" id="outputText">
            <div class="output-empty">
              <div class="empty-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  <path d="M9 12l2 2 4-4"/>
                </svg>
              </div>
              <p>Masked output will appear here</p>
            </div>
          </div>
          <div class="output-stats" id="outputStats"></div>
        </div>
      </div>

      <!-- Legend -->
      <div class="legend glass">
        <h3>Entity Type Legend</h3>
        <div class="legend-tags">
          <span class="legend-tag tag-phone">Phone</span>
          <span class="legend-tag tag-email">Email</span>
          <span class="legend-tag tag-idcard">ID Card</span>
          <span class="legend-tag tag-bank">Bank Card</span>
          <span class="legend-tag tag-person">Name</span>
          <span class="legend-tag tag-location">Address</span>
          <span class="legend-tag tag-org">Org</span>
        </div>
      </div>

      <!-- Entities Table -->
      <div class="entities-panel glass" id="entitiesPanel" style="display: none;">
        <div class="entities-header">
          <h3>Detected Entities</h3>
          <span class="entities-count" id="entitiesCount">0 items</span>
        </div>
        <div class="entities-table-wrap">
          <table class="entities-table">
            <thead>
              <tr>
                <th>Type</th>
                <th>Original Value</th>
                <th>Placeholder</th>
                <th>Position</th>
              </tr>
            </thead>
            <tbody id="entitiesBody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <Footer />

  <!-- WebApplication Structured Data -->
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "AI Privacy Gateway — Online PII Masking Demo",
    "url": "https://privacygw.pages.dev/demo",
    "description": "Free interactive demo showing real-time PII detection and masking. Paste text and see phone numbers, emails, ID cards get masked instantly.",
    "applicationCategory": "SecurityApplication",
    "operatingSystem": "All",
    "browserRequirements": "Requires JavaScript",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  }</script>

  <script is:inline>
    const API_ENDPOINT = import.meta.env.PUBLIC_API_URL || 'http://localhost:9999/api/mask';
    let isProcessing = false;

    function loadExample() {
      document.getElementById('inputText').value = `张三住在北京市海淀区中关村大街1号，联系电话13812345678，邮箱test@example.com。\n身份证号：110101199001011234，银行卡号：6222021234567890123。\n公司名称：北京科技有限公司，车牌号：京A12345，IP地址：192.168.1.100。\n今天是2024年1月15日，转账金额¥999.99，邮编100080。`;
    }

    function clearText() {
      document.getElementById('inputText').value = '';
      document.getElementById('outputText').innerHTML =
        '<div class="output-empty"><div class="empty-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg></div><p>Masked output will appear here</p></div>';
      document.getElementById('outputStats').innerHTML = '';
      document.getElementById('entitiesPanel').style.display = 'none';
    }

    async function processText() {
      const input = document.getElementById('inputText').value.trim();
      if (!input) { alert('Please enter text to mask'); return; }
      if (isProcessing) return;
      isProcessing = true;

      const outputDiv = document.getElementById('outputText');
      outputDiv.innerHTML = '<div class="output-loading"><div class="spinner"></div><p>Detecting sensitive data...</p></div>';
      document.getElementById('outputStats').innerHTML = '';
      document.getElementById('entitiesPanel').style.display = 'none';

      try {
        const response = await fetch(API_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text: input })
        });
        const result = await response.json();
        displayResult(result);
      } catch (error) {
        outputDiv.innerHTML = '<div class="output-error"><div class="error-icon">!</div><p>Connection failed. Make sure the gateway is running at <strong>http://localhost:9999</strong></p></div>';
        console.error('API Error:', error);
      } finally {
        isProcessing = false;
      }
    }

    function displayResult(result) {
      const outputDiv = document.getElementById('outputText');
      const statsDiv = document.getElementById('outputStats');
      const entitiesPanel = document.getElementById('entitiesPanel');
      const entitiesBody = document.getElementById('entitiesBody');
      const entitiesCount = document.getElementById('entitiesCount');

      const tagMap = {
        'PII_PHONE': 'tag-phone', 'PII_EMAIL': 'tag-email', 'PII_IDCARD': 'tag-idcard',
        'PII_BANK': 'tag-bank', 'PII_PER': 'tag-person', 'PII_LOC': 'tag-location',
        'PII_ORG': 'tag-org', 'PII_PLATE': 'tag-org', 'PII_IP': 'tag-email',
        'PII_URL': 'tag-phone', 'PII_DATE': 'tag-idcard', 'PII_AMOUNT': 'tag-bank',
        'PII_POSTCODE': 'tag-location', 'PII_CUST': 'tag-person',
      };

      const typeNames = {
        'PII_PHONE': 'Phone', 'PII_EMAIL': 'Email', 'PII_IDCARD': 'ID Card',
        'PII_BANK': 'Bank Card', 'PII_PER': 'Name', 'PII_LOC': 'Address',
        'PII_ORG': 'Org', 'PII_PLATE': 'License Plate', 'PII_IP': 'IP',
        'PII_URL': 'URL', 'PII_DATE': 'Date', 'PII_AMOUNT': 'Amount',
        'PII_POSTCODE': 'Postal Code', 'PII_CUST': 'Custom'
      };

      let html = escapeHtml(result.masked_text);
      result.entities.forEach(function(entity) {
        var tag = tagMap[entity.type] || 'tag-org';
        var re = new RegExp(escapeRegex(escapeHtml(entity.placeholder)), 'g');
        html = html.replace(re,
          '<mark class="' + tag + '">' + escapeHtml(entity.placeholder) + '</mark>');
      });
      outputDiv.innerHTML = '<pre class="output-content">' + html + '</pre>';

      var totalMasked = 0;
      for (var key in (result.stats || {})) {
        totalMasked += (result.stats[key] || 0);
      }
      statsDiv.innerHTML =
        '<div class="stats-row">' +
          '<div class="stat-block"><span class="stat-val">' + totalMasked + '</span><span class="stat-lbl">Entities Detected</span></div>' +
          '<div class="stat-block"><span class="stat-val">' + result.entities.length + '</span><span class="stat-lbl">Replacements</span></div>' +
        '</div>';

      if (result.entities && result.entities.length > 0) {
        entitiesPanel.style.display = 'block';
        entitiesCount.textContent = result.entities.length + ' items';
        entitiesBody.innerHTML = result.entities.map(function(e) {
          return '<tr>' +
            '<td><span class="entity-tag ' + (tagMap[e.type] || 'tag-org') + '">' + (typeNames[e.type] || e.type) + '</span></td>' +
            '<td class="entity-val">' + escapeHtml(e.value) + '</td>' +
            '<td class="entity-ph">' + escapeHtml(e.placeholder) + '</td>' +
            '<td>' + e.position + '</td>' +
          '</tr>';
        }).join('');
      }
    }

    function escapeHtml(text) {
      var d = document.createElement('div');
      d.textContent = text;
      return d.innerHTML;
    }

    function escapeRegex(text) {
      return text.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }

    // Load example on page load
    loadExample();
  </script>

  <style>
    .hero {
      padding: 10rem 0 4rem;
      position: relative;
      overflow: hidden;
    }

    .hero-orb-1 {
      position: absolute; top: -200px; right: -100px;
      width: 600px; height: 600px;
      background: radial-gradient(circle, var(--primary-glow) 0%, rgba(134, 239, 172, 0.05) 40%, transparent 60%);
      border-radius: 50%; filter: blur(100px);
      animation: orb-demo 16s ease-in-out infinite;
      pointer-events: none;
    }

    .hero-orb-2 {
      position: absolute; bottom: -150px; left: -100px;
      width: 450px; height: 450px;
      background: radial-gradient(circle, var(--accent-glow) 0%, rgba(167, 139, 250, 0.05) 40%, transparent 60%);
      border-radius: 50%; filter: blur(80px);
      animation: orb-demo 20s ease-in-out infinite -6s;
      pointer-events: none;
    }

    @keyframes orb-demo {
      0%, 100% { transform: translateY(0) scale(1); }
      50% { transform: translateY(-20px) scale(1.05); }
    }

    .hero-content { text-align: center; position: relative; z-index: 1; }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--glass-bg);
      backdrop-filter: var(--glass-blur);
      padding: 0.5rem 1rem;
      border-radius: 20px;
      font-size: 0.85rem;
      color: var(--primary);
      margin-bottom: 1.5rem;
      border: 1px solid var(--border);
    }

    .hero-title {
      font-size: 3.5rem;
      font-weight: 700;
      letter-spacing: -0.04em;
      margin-bottom: 1.25rem;
    }

    .hero-desc {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 580px;
      margin: 0 auto;
      line-height: 1.8;
    }

    /* --- Demo Section --- */
    .demo-section { padding: 4rem 0 6rem; position: relative; z-index: 1; }

    .demo-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      max-width: 1200px;
      margin: 0 auto 2rem;
    }

    .demo-panel {
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
    }

    .panel-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.75rem;
    }

    .panel-head h2 {
      margin: 0;
      font-size: 1rem;
      color: var(--text-primary);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .panel-indicator {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      display: inline-block;
    }

    .input-indicator { background: var(--warning); box-shadow: 0 0 8px rgba(251, 191, 36, 0.4); }
    .output-indicator { background: var(--primary); box-shadow: 0 0 8px var(--primary-glow); }

    .panel-badge {
      font-size: 0.7rem;
      padding: 0.2rem 0.75rem;
      border-radius: 20px;
      font-weight: 600;
    }

    .badge-input { background: rgba(251, 191, 36, 0.1); color: var(--warning); }
    .badge-output { background: rgba(134, 239, 172, 0.1); color: var(--primary); }

    .demo-textarea {
      flex: 1;
      width: 100%;
      min-height: 260px;
      padding: 1rem;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: var(--bg-deep);
      color: var(--text-primary);
      font-family: 'JetBrains Mono', 'Fira Code', monospace;
      font-size: 0.88rem;
      line-height: 1.7;
      resize: vertical;
      outline: none;
      transition: border-color 0.3s ease;
    }

    .demo-textarea:focus {
      border-color: var(--border-glow);
      box-shadow: 0 0 12px rgba(134, 239, 172, 0.06);
    }

    .demo-textarea::placeholder {
      color: var(--text-dim);
    }

    .panel-toolbar {
      display: flex;
      gap: 0.5rem;
      margin-top: 0.75rem;
    }

    .btn-sm { padding: 0.45rem 1rem; font-size: 0.82rem; border-radius: 8px; }

    .btn-secondary {
      background: var(--glass-bg);
      color: var(--text-primary);
      border: 1px solid var(--border);
      backdrop-filter: var(--glass-blur);
      cursor: pointer;
      transition: all 0.25s ease;
    }

    @media (hover: hover) {
      .btn-secondary:hover {
        border-color: var(--primary);
        color: var(--primary);
      }
    }

    .btn-full {
      width: 100%;
      margin-top: 0.75rem;
      padding: 0.85rem;
      font-size: 1rem;
    }

    /* Output panel */
    .demo-output {
      flex: 1;
      min-height: 260px;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem;
      background: var(--bg-deep);
      overflow: auto;
      transition: border-color 0.3s;
    }

    .output-empty {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 220px;
      color: var(--text-muted);
      gap: 0.75rem;
    }

    .empty-icon {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: rgba(134, 239, 172, 0.05);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-dim);
      border: 1px solid var(--border);
    }

    .empty-icon svg { width: 26px; height: 26px; }

    .output-empty p { font-size: 0.9rem; }

    .output-content {
      white-space: pre-wrap;
      word-wrap: break-word;
      margin: 0;
      color: var(--text-primary);
      font-family: 'JetBrains Mono', 'Fira Code', monospace;
      font-size: 0.88rem;
      line-height: 1.7;
    }

    .output-loading {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 220px;
      color: var(--text-muted);
      gap: 0.75rem;
    }

    .spinner {
      width: 32px;
      height: 32px;
      border: 3px solid var(--border);
      border-top-color: var(--primary);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .output-error {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 220px;
      color: var(--danger);
      text-align: center;
      padding: 1rem;
      gap: 0.75rem;
    }

    .error-icon {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(248, 113, 113, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 1.25rem;
    }

    .output-error p { font-size: 0.88rem; }
    .output-error strong { color: var(--text-primary); }

    .output-stats { margin-top: 0.75rem; }

    .stats-row {
      display: flex;
      gap: 0.75rem;
    }

    .stat-block {
      flex: 1;
      text-align: center;
      padding: 0.75rem;
      background: var(--bg-deep);
      border-radius: 8px;
      border: 1px solid var(--border);
    }

    .stat-val {
      display: block;
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--primary);
    }

    .stat-lbl {
      display: block;
      font-size: 0.75rem;
      color: var(--text-secondary);
      margin-top: 0.15rem;
    }

    /* Legend */
    .legend {
      padding: 1.25rem 1.5rem;
      margin-bottom: 2rem;
      max-width: 1200px;
      margin-left: auto;
      margin-right: auto;
    }

    .legend h3 {
      margin: 0 0 0.75rem;
      font-size: 0.9rem;
      color: var(--text-primary);
    }

    .legend-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .legend-tag {
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.78rem;
      font-weight: 500;
    }

    .tag-phone { background: rgba(251, 191, 36, 0.12); color: #fbbf24; }
    .tag-email { background: rgba(96, 165, 250, 0.12); color: #60a5fa; }
    .tag-idcard { background: rgba(134, 239, 172, 0.12); color: var(--primary); }
    .tag-bank { background: rgba(244, 114, 182, 0.12); color: #f472b6; }
    .tag-person { background: rgba(167, 139, 250, 0.12); color: var(--accent); }
    .tag-location { background: rgba(252, 165, 165, 0.12); color: #fca5a5; }
    .tag-org { background: rgba(148, 163, 184, 0.12); color: #94a3b8; }

    /* Entities table */
    .entities-panel {
      padding: 1.5rem;
      margin-bottom: 2rem;
      max-width: 1200px;
      margin-left: auto;
      margin-right: auto;
    }

    .entities-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }

    .entities-header h3 {
      margin: 0;
      font-size: 0.9rem;
      color: var(--text-primary);
    }

    .entities-count {
      font-size: 0.78rem;
      color: var(--text-muted);
    }

    .entities-table-wrap { overflow-x: auto; }

    .entities-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
    }

    .entities-table th,
    .entities-table td {
      padding: 0.65rem 0.85rem;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }

    .entities-table th {
      background: var(--bg-deep);
      font-weight: 600;
      color: var(--text-secondary);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    @media (hover: hover) {
      .entities-table tr:hover td {
        background: rgba(134, 239, 172, 0.02);
      }
    }

    .entity-tag {
      padding: 0.15rem 0.45rem;
      border-radius: 4px;
      font-size: 0.7rem;
      font-weight: 600;
    }

    .entity-val {
      font-family: 'JetBrains Mono', monospace;
      color: var(--text-primary);
    }
    .entity-ph {
      font-family: 'JetBrains Mono', monospace;
      color: var(--primary);
    }

    /* Highlight marks in output */
    mark.tag-phone { background: rgba(251, 191, 36, 0.2); color: #fbbf24; border-radius: 3px; padding: 0 3px; }
    mark.tag-email { background: rgba(96, 165, 250, 0.2); color: #60a5fa; border-radius: 3px; padding: 0 3px; }
    mark.tag-idcard { background: rgba(134, 239, 172, 0.2); color: var(--primary); border-radius: 3px; padding: 0 3px; }
    mark.tag-bank { background: rgba(244, 114, 182, 0.2); color: #f472b6; border-radius: 3px; padding: 0 3px; }
    mark.tag-person { background: rgba(167, 139, 250, 0.2); color: var(--accent); border-radius: 3px; padding: 0 3px; }
    mark.tag-location { background: rgba(252, 165, 165, 0.2); color: #fca5a5; border-radius: 3px; padding: 0 3px; }
    mark.tag-org { background: rgba(148, 163, 184, 0.2); color: #94a3b8; border-radius: 3px; padding: 0 3px; }

    /* Responsive */
    @media (max-width: 768px) {
      .hero-title { font-size: 2.25rem; }
      .hero { padding: 7rem 0 3rem; }
      .demo-grid { grid-template-columns: 1fr; }
      .panel-toolbar { flex-direction: column; }
      .panel-toolbar .btn { width: 100%; }
    }

    @media (max-width: 639px) {
      .hero-title { font-size: 2rem; }
      .hero-desc { font-size: 0.95rem; }
    }
  </style>
</Layout>
