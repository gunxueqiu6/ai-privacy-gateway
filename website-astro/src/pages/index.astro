    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    border: 1px solid var(--border);
  }

  /* Performance card */
  .bento-perf { grid-column: span 2; grid-row: span 1; }
  .bento-perf .bento-card-inner {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .bento-perf-icon svg {
    width: 36px;
    height: 36px;
    color: var(--primary);
