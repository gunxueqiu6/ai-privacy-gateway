---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="AI Privacy Gateway — Your AI data is leaking PII right now. Install a firewall in 30 seconds."
  description="Open-source AI API privacy gateway. Auto-detect and mask phone numbers, emails, ID cards, bank cards, and more before they reach AI models. 30-second deploy. MIT licensed."
  canonicalURL="https://privacygw.pages.dev">
  <Nav />

  <!-- ============================================
       HERO — "Your data is leaking. Fix it."
       ============================================ -->
  <section class="hero">
    <div class="hero-grid-bg"></div>
    <div class="hero-orb-1"></div>
    <div class="hero-orb-2"></div>
    <div class="hero-orb-3"></div>
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge">
          <span class="pulse-dot"></span>
          <span>v1.1.0 &middot; MIT Licensed &middot; Open Source</span>
        </div>

        <h1 class="hero-title">
          Your AI data is leaking<br/>
          <span class="gradient-text">PII right now.</span><br/>
          Install a firewall in 30 seconds.
        </h1>

        <p class="hero-desc">
          AI Privacy Gateway intercepts every API call to LLMs&mdash;detecting and masking
          phone numbers, emails, ID cards, bank cards, and<br class="hide-mobile"/>
          <strong>14 entity types</strong> before they leave your machine.
        </p>

        <div class="hero-actions">
          <a href="/download" class="btn btn-primary btn-lg">
            Deploy Now
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="/demo" class="btn btn-ghost btn-lg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <polygon points="5 3 19 12 5 21 5 3"/>
            </svg>
            Watch Demo
          </a>
          <a href="https://github.com/gunxueqiu6/ai-privacy-gateway" class="btn btn-ghost btn-lg">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
        </div>

        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hero-stat-num">14</span>
            <span class="hero-stat-label">Entity Types Detected</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-num">&lt;1ms</span>
            <span class="hero-stat-label">Avg. Latency Added</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-num">10K+</span>
            <span class="hero-stat-label">QPS Per Instance</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-num">0</span>
            <span class="hero-stat-label">Data Ever Uploaded</span>
          </div>
        </div>

        <!-- Before / After masking example -->
        <div class="masking-demo glass">
          <div class="masking-header">
            <div class="masking-tabs">
              <span class="masking-tab active" data-tab="before">Raw Request</span>
              <span class="masking-tab" data-tab="after">Masked &#8594; AI</span>
            </div>
            <span class="masking-badge">Live Preview</span>
          </div>
          <div class="masking-body" id="masking-body">
            <pre class="masking-code" id="masking-before"><code>&#123;
  <span class="key">"model"</span>: <span class="str">"gpt-4"</span>,
  <span class="key">"messages"</span>: [&#123;
    <span class="key">"role"</span>: <span class="str">"user"</span>,
    <span class="key">"content"</span>: <span class="str">"My phone is <span class="pii pii-phone">13812345678</span>,
    email is <span class="pii pii-email">alice@example.com</span>,
    and my ID is <span class="pii pii-id">110101199001011234</span>."</span>
  &#125;]
&#125;</code></pre>
            <pre class="masking-code hidden" id="masking-after"><code>&#123;
  <span class="key">"model"</span>: <span class="str">"gpt-4"</span>,
  <span class="key">"messages"</span>: [&#123;
    <span class="key">"role"</span>: <span class="str">"user"</span>,
    <span class="key">"content"</span>: <span class="str">"My phone is <span class="pii-masked">[PHONE_1]</span>,
    email is <span class="pii-masked">[EMAIL_1]</span>,
    and my ID is <span class="pii-masked">[IDCARD_1]</span>."</span>
  &#125;]
&#125;</code></pre>
          </div>
          <div class="masking-footer">
            <span class="masking-protected">&#10003; All PII masked before reaching AI</span>
          </div>
        </div>

        <p class="hero-integrations">
          Works with <strong>ChatGPT</strong>, <strong>Claude</strong>, <strong>DeepSeek</strong>,
          <strong>Cursor</strong>, <strong>Kimi</strong> &mdash; any OpenAI-compatible API.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================
       PROBLEM — Why you need this
       ============================================ -->
  <section class="problem" id="problem">
    <div class="container">
      <div class="section-label">The Risk</div>
      <h2 class="section-title">Every AI call exposes your<br/>sensitive data</h2>
      <p class="section-subtitle">
        Every time you paste code, patient records, or customer data into an AI prompt,
        that information leaves your control. Here is what is at stake.
      </p>

      <div class="problem-grid">
        <div class="problem-card glass glow-hover">
          <div class="problem-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3>Data at rest nowhere</h3>
          <p>Phone numbers, emails, addresses, and bank cards fly through third-party servers every time you use an AI tool.</p>
          <div class="problem-stat">
            <span class="problem-stat-num">78%</span>
            <span class="problem-stat-label">of corporate AI prompts contain PII</span>
          </div>
        </div>

        <div class="problem-card glass glow-hover">
          <div class="problem-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <h3>Training data leaks</h3>
          <p>LLMs memorize patterns. Your data could resurface in another user's session — a documented risk in production AI systems.</p>
          <div class="problem-stat">
            <span class="problem-stat-num risk-warn">Known</span>
            <span class="problem-stat-label">Model inversion &amp; extraction attacks</span>
          </div>
        </div>

        <div class="problem-card glass glow-hover">
          <div class="problem-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <h3>Regulatory exposure</h3>
          <p>Sending PII to third-party AI APIs without masking violates GDPR, CCPA, PIPL, and HIPAA. Fines can reach millions.</p>
          <div class="problem-stat">
            <span class="problem-stat-num risk-danger">&euro;20M+</span>
            <span class="problem-stat-label">GDPR max fine per violation</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       HOW IT WORKS — Step flow
       ============================================ -->
  <section class="how-it-works" id="how-it-works">
    <div class="container">
      <div class="section-label">How It Works</div>
      <h2 class="section-title">Three steps. Zero code changes.</h2>
      <p class="section-subtitle">
        Point your API base URL to the gateway. Everything else is automatic.
      </p>

      <div class="steps-visual">
        <div class="step-card-wrapper">
          <div class="step-card glass">
            <div class="step-num">01</div>
            <div class="step-card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
              </svg>
            </div>
            <h3>Intercept</h3>
            <p>Gateway captures every request headed to your AI provider</p>
          </div>
          <div class="step-arrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        </div>

        <div class="step-card-wrapper">
          <div class="step-card glass">
            <div class="step-num">02</div>
            <div class="step-card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <h3>Detect &amp; Mask</h3>
            <p>14 entity types identified via regex + NER, replaced with safe placeholders</p>
          </div>
          <div class="step-arrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        </div>

        <div class="step-card-wrapper">
          <div class="step-card glass">
            <div class="step-num">03</div>
            <div class="step-card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <h3>Forward &amp; Restore</h3>
            <p>Masked data sent to LLM; response placeholders restored before returning to you</p>
          </div>
        </div>
      </div>

      <!-- Quick code example -->
      <div class="code-compare glass">
        <div class="code-compare-header">
          <span>One-line change. Any SDK.</span>
        </div>
        <div class="code-compare-grid">
          <div class="code-panel">
            <div class="code-panel-label before-label">Before</div>
            <pre><code><span class="code-cmt"># Unprotected — direct to AI</span>
client = OpenAI(
  api_key="sk-...",
  <span class="code-highlight">base_url="https://api.openai.com/v1"</span>
)</code></pre>
          </div>
          <div class="code-panel">
            <div class="code-panel-label after-label">After</div>
            <pre><code><span class="code-cmt"># Protected — via gateway</span>
client = OpenAI(
  api_key="sk-...",
  <span class="code-highlight code-highlight-green">base_url="http://localhost:9999/v1"</span>
)</code></pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       FEATURES — Bento grid
       ============================================ -->
  <section class="features" id="features">
    <div class="container">
      <div class="section-label">Capabilities</div>
      <h2 class="section-title">Enterprise-grade privacy,<br/>developer-friendly DX</h2>
      <p class="section-subtitle">
        Built for teams that ship fast and care about data security.
        Every feature ships in the free Lite edition.
      </p>

      <div class="bento">

        <!-- Main: Detection engine -->
        <div class="bento-card bento-main glass glow-hover">
          <div class="bento-badge">Core Engine</div>
          <div class="bento-card-content">
            <div class="bento-icon-large">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <h3>Intelligent Masking Engine</h3>
            <p>Regex + NER dual-engine detects 14 entity types: phone, email, ID card, bank card, name, address, license plate, IP, URL, date, amount, postal code, organization, and custom keywords. Zero configuration.</p>
            <div class="entity-chips">
              <span class="chip chip-phone">Phone</span>
              <span class="chip chip-email">Email</span>
              <span class="chip chip-id">ID Card</span>
              <span class="chip chip-bank">Bank Card</span>
              <span class="chip chip-name">Name</span>
              <span class="chip chip-loc">Address</span>
              <span class="chip chip-org">Org</span>
              <span class="chip chip-more">+7 more</span>
            </div>
          </div>
          <div class="bento-metrics">
            <div class="bento-metric">
              <span class="bento-metric-num">14</span>
              <span class="bento-metric-label">Entity Types</span>
            </div>
            <div class="bento-metric">
              <span class="bento-metric-num">&lt;1ms</span>
              <span class="bento-metric-label">Detection Latency</span>
            </div>
            <div class="bento-metric">
              <span class="bento-metric-num">93%</span>
              <span class="bento-metric-label">Coverage Rate</span>
            </div>
          </div>
        </div>

        <!-- Streaming -->
        <div class="bento-card glass glow-hover">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4 17 10 11 4 5"/>
              <line x1="12" y1="19" x2="20" y2="19"/>
            </svg>
          </div>
          <h3>SSE Streaming</h3>
          <p>Full SSE proxy with real-time masking and unmasking. Zero added perceptible latency.</p>
        </div>

        <!-- Local storage -->
        <div class="bento-card glass glow-hover">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            </svg>
          </div>
          <h3>Local SQLite Vault</h3>
          <p>Encrypted local storage. Mapping data never leaves your machine.</p>
        </div>

        <!-- 30s deploy -->
        <div class="bento-card glass glow-hover">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h3>30-Second Deploy</h3>
          <p>Single binary, Docker, or pip. Download and run. No dependencies.</p>
        </div>

        <!-- Architecture -->
        <div class="bento-card bento-arch glass glow-hover">
          <div class="bento-badge">Architecture</div>
          <div class="bento-card-content">
            <h3>Data Flow Pipeline</h3>
            <p>Request enters gateway &rarr; regex scan &rarr; NER inference &rarr; placeholder replacement &rarr; forward to LLM. Response reverses the pipeline. End-to-end under 1ms overhead.</p>
            <div class="flow-pipeline">
              <div class="pipeline-node">Client</div>
              <span class="pipeline-arrow">&rarr;</span>
              <div class="pipeline-node pipeline-accent">Gateway</div>
              <span class="pipeline-arrow">&rarr;</span>
              <div class="pipeline-node">LLM</div>
            </div>
            <div class="pipeline-tags">
              <span class="pipeline-tag">Regex Match</span>
              <span class="pipeline-tag">NER Detect</span>
              <span class="pipeline-tag">Map &amp; Replace</span>
              <span class="pipeline-tag">Reverse on Response</span>
            </div>
          </div>
        </div>

        <!-- Custom rules -->
        <div class="bento-card glass glow-hover">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </div>
          <h3>Custom Rules</h3>
          <p>Regex + keyword patterns for domain-specific PII. Flexible and extensible.</p>
        </div>

        <!-- Admin dashboard -->
        <div class="bento-card glass glow-hover">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <h3>Admin Dashboard</h3>
          <p>Real-time stats: masking count, entity distribution, mapping records, and throughput.</p>
        </div>

        <!-- Open source -->
        <div class="bento-card glass glow-hover">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3>MIT Licensed</h3>
          <p>Free forever. Personal use, commercial use, self-hosted. No restrictions.</p>
        </div>

        <!-- Performance -->
        <div class="bento-card bento-perf glass glow-hover">
          <div class="bento-card-inner">
            <div class="bento-perf-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
              </svg>
            </div>
            <div class="bento-perf-content">
              <h3>Performance Benchmarks</h3>
              <p>P99 latency under 2ms. Single instance handles 10,000+ QPS. Zero data leaves your network.</p>
              <div class="perf-bars">
                <div class="perf-bar">
                  <span class="perf-bar-label">Regex Matching</span>
                  <div class="perf-bar-track">
                    <div class="perf-bar-fill" style="width:95%"></div>
                  </div>
                  <span class="perf-bar-val">0.3ms</span>
                </div>
                <div class="perf-bar">
                  <span class="perf-bar-label">NER Inference</span>
                  <div class="perf-bar-track">
                    <div class="perf-bar-fill perf-fill-accent" style="width:88%"></div>
                  </div>
                  <span class="perf-bar-val">0.8ms</span>
                </div>
                <div class="perf-bar">
                  <span class="perf-bar-label">Map Restore</span>
                  <div class="perf-bar-track">
                    <div class="perf-bar-fill perf-fill-green" style="width:98%"></div>
                  </div>
                  <span class="perf-bar-val">0.1ms</span>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================
       COMPATIBILITY — Platform cards
       ============================================ -->
  <section class="compat">
    <div class="container">
      <div class="section-label">Compatibility</div>
      <h2 class="section-title">Works with everything</h2>
      <p class="section-subtitle">
        Drop-in proxy for any OpenAI-compatible API. No SDK changes, no vendor lock-in.
      </p>

      <div class="compat-grid">
        <div class="compat-card glass">
          <div class="compat-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M15.4 2.4C18.3 4.5 20.5 8.2 20.5 12c0 3.8-2.2 7.5-5.1 9.6-.3.2-.6.4-.9.6l-.6-1.2c.3-.2.6-.4.8-.6 2.4-1.8 4.1-5.3 4.1-8.4s-1.7-6.6-4.1-8.4c-.3-.2-.5-.4-.8-.6l.6-1.2c.3.2.6.4.9.6zM8.6 2.4c.3.2.6.4.9.6l.6 1.2c-.3.2-.6.4-.8.6C6.9 6.6 5.6 10.1 5.6 12s1.3 5.4 3.7 7.2c.3.2.5.4.8.6l-.6 1.2c-.3-.2-.6-.4-.9-.6C5.7 18.4 3.5 14.7 3.5 12s2.2-6.4 5.1-9.6zM12 2c1.1 0 2 .9 2 2v16c0 1.1-.9 2-2 2s-2-.9-2-2V4c0-1.1.9-2 2-2z"/></svg>
          </div>
          <span class="compat-name">Python SDK</span>
        </div>
        <div class="compat-card glass">
          <div class="compat-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.4 0-8-3.6-8-8s3.6-8 8-8 8 3.6 8 8-3.6 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/></svg>
          </div>
          <span class="compat-name">JavaScript SDK</span>
        </div>
        <div class="compat-card glass">
          <div class="compat-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 2h-11C5.1 2 4 3.1 4 4.5v15C4 20.9 5.1 22 6.5 22h11c1.4 0 2.5-1.1 2.5-2.5v-15C20 3.1 18.9 2 17.5 2zM12 20c-.8 0-1.5-.7-1.5-1.5S11.2 17 12 17s1.5.7 1.5 1.5S12.8 20 12 20zm5-4H7V5h10v11z"/></svg>
          </div>
          <span class="compat-name">Flutter SDK</span>
        </div>
        <div class="compat-card glass">
          <div class="compat-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 18c0 .6.4 1 1 1h2c.6 0 1-.4 1-1v-2H6v2zM14 18c0 .6.4 1 1 1h2c.6 0 1-.4 1-1v-2h-4v2zM4 8v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8H4zm16-2V4c0-1.1-.9-2-2-2H6C4.9 2 4 2.9 4 4v2h16z"/></svg>
          </div>
