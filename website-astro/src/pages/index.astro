<script is:inline>
  (function() {
    // Masking demo tab toggle
    var tabs = document.querySelectorAll('.masking-tab');
    var beforePane = document.getElementById('masking-before');
    var afterPane = document.getElementById('masking-after');

    if (tabs.length && beforePane && afterPane) {
      tabs.forEach(function(tab) {
        tab.addEventListener('click', function() {
          tabs.forEach(function(t) { t.classList.remove('active'); });
          tab.classList.add('active');
          if (tab.dataset.tab === 'before') {
            beforePane.classList.remove('hidden');
            afterPane.classList.add('hidden');
          } else {
            beforePane.classList.add('hidden');
            afterPane.classList.remove('hidden');
          }
        });
      });

      // Auto-switch to "after" after 3s to demonstrate the effect
      setTimeout(function() {
        var afterTab = document.querySelector('.masking-tab[data-tab="after"]');
        if (afterTab) afterTab.click();
      }, 3000);

      // Switch back after 6s
      setTimeout(function() {
        var beforeTab = document.querySelector('.masking-tab[data-tab="before"]');
        if (beforeTab) beforeTab.click();
      }, 6000);

      // Cycle again
      setTimeout(function() {
        var afterTab = document.querySelector('.masking-tab[data-tab="after"]');
        if (afterTab) afterTab.click();
      }, 9000);
    }
  })();
</script>
