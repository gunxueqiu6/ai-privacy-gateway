    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .bento-icon { margin-bottom: 0.75rem; }
  .bento-icon svg { width: 24px; height: 24px; color: var(--primary); }

  .bento-card:not(.bento-main):not(.bento-arch):not(.bento-perf) h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .bento-card:not(.bento-main):not(.bento-arch):not(.bento-perf) p {
    color: var(--text-secondary);
    font-size: 0.85rem;
    line-height: 1.6;
    flex: 1;
  }

  /* Architecture card */
  .bento-arch {
    grid-column: span 2;
    grid-row: span 1;
  }

  .pipeline-flow { margin: 0.75rem 0 0.5rem; }

  .flow-pipeline {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    justify-content: center;
    margin: 1rem 0;
    padding: 0.75rem;
    background: rgba(0, 0, 0, 0.2);
    border-radius: 10px;
    border: 1px solid var(--border);
  }

  .pipeline-node {
    padding: 0.3rem 0.75rem;
