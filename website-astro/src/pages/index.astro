    grid-row: span 2;
    padding: 2.25rem;
    position: relative;
    overflow: hidden;
  }

  .bento-main::after {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(134, 239, 172, 0.05), transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .bento-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.25rem;
  }

  .bento-icon-large {
    margin-bottom: 1rem;
  }

  .bento-icon-large svg {
    width: 32px;
    height: 32px;
    color: var(--primary);
  }

  .bento-card-content { flex: 1; }
  .bento-card-content h3 { font-size: 1.3rem; margin-bottom: 0.75rem; }
