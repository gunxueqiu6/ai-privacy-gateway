---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AI Privacy Gateway - AI 数据隐私保护">
  <!-- Hero Section -->
  <section class="hero">
    <div class="gradient-orb gradient-orb-1"></div>
    <div class="gradient-orb gradient-orb-2"></div>

    <div class="container">
      <div class="hero-content fade-in">
        <h1>你的团队 AI 数据<br><span class="highlight">正在裸奔</span></h1>
        <p class="hero-subtitle">30 秒装上防火墙，自动脱敏敏感信息</p>

        <div class="cta-buttons">
          <a href="#pricing" class="btn btn-primary">立即购买 Pro 版</a>
          <a href="https://github.com/gunxueqiu6/ai-privacy-gateway" class="btn btn-secondary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            GitHub 免费下载
          </a>
        </div>

        <p class="supported-platforms">
          支持 DeepSeek / Claude / ChatGPT / Cursor 等所有 AI 服务
        </p>
      </div>
    </div>
  </section>

  <!-- Problem Section -->
  <section class="problems">
    <div class="container">
      <h2 class="section-title">真实场景，真实风险</h2>

      <div class="problem-grid">
        <div class="glass problem-card">
          <div class="problem-icon">💼</div>
          <h3>Cursor 里贴身份证</h3>
          <p>开发者为了调试，把用户身份证号贴进 Cursor 对话，训练数据被抓取</p>
        </div>

        <div class="glass problem-card">
          <div class="problem-icon">📱</div>
          <h3>飞书机器人泄露手机号</h3>
          <p>客服机器人在对话中暴露客户手机号，被竞争对手获取</p>
        </div>

        <div class="glass problem-card">
          <div class="problem-icon">🔓</div>
          <h3>DeepSeek 训练数据被抓取</h3>
          <p>API 请求被第三方缓存，敏感数据流入训练集</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="features">
    <div class="container">
      <h2 class="section-title">核心功能</h2>

      <div class="features-bento">
        <div class="glass feature-card feature-large">
          <div class="feature-icon">🔒</div>
          <h3>自动脱敏</h3>
          <p>手机号、身份证、邮箱、银行卡等敏感信息自动识别并替换为 [VAULT_xxx] 占位符</p>
          <div class="feature-demo">
            <code>13812345678 → [VAULT_PHONE_a1b2c3]</code>
          </div>
        </div>

        <div class="glass feature-card">
          <div class="feature-icon">⚡</div>
          <h3>流式支持</h3>
          <p>完美支持 AI 流式输出 SSE，用户完全无感知</p>
        </div>

        <div class="glass feature-card">
          <div class="feature-icon">🏠</div>
          <h3>本地存储</h3>
          <p>所有数据仅存储在本地 SQLite，映射关系不上传任何云端</p>
        </div>

        <div class="glass feature-card">
          <div class="feature-icon">🔌</div>
          <h3>一键接入</h3>
          <p>只需改一个 API 地址，无需修改任何代码</p>
        </div>

        <div class="glass feature-card">
          <div class="feature-icon">📊</div>
          <h3>团队看板</h3>
          <p>实时查看团队拦截统计，会话查询追溯</p>
        </div>

        <div class="glass feature-card">
          <div class="feature-icon">☁️</div>
          <h3>云端规则</h3>
          <p>敏感词规则自动更新，无需手动维护</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="how-it-works">
    <div class="container">
      <h2 class="section-title">工作原理</h2>

      <div class="steps">
        <div class="glass step-card">
          <div class="step-number">1</div>
          <h3>拦截请求</h3>
          <p>你的 AI 客户端发送请求，包含敏感数据</p>
        </div>

        <div class="step-connector">→</div>

        <div class="glass step-card">
          <div class="step-number">2</div>
          <h3>自动脱敏</h3>
          <p>网关识别并替换敏感数据为占位符</p>
        </div>

        <div class="step-connector">→</div>

        <div class="glass step-card">
          <div class="step-number">3</div>
          <h3>转发 AI</h3>
          <p>脱敏后的请求转发到目标 AI 服务</p>
        </div>

        <div class="step-connector">→</div>

        <div class="glass step-card">
          <div class="step-number">4</div>
          <h3>还原返回</h3>
          <p>响应中的占位符还原为原始值返回</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="pricing" id="pricing">
    <div class="container">
      <h2 class="section-title">版本对比</h2>

      <div class="pricing-grid">
        <div class="glass pricing-card">
          <h3>Lite 个人版</h3>
          <div class="price">免费</div>
          <ul class="feature-list">
            <li>正则脱敏（手机/邮箱/身份证/银行卡）</li>
            <li>流式代理 + 缓冲</li>
            <li>自定义敏感词（手动添加）</li>
            <li>基础管理后台</li>
            <li class="disabled">多人并发</li>
            <li class="disabled">团队看板</li>
            <li class="disabled">云端规则更新</li>
          </ul>
          <a href="https://github.com/gunxueqiu6/ai-privacy-gateway" class="btn btn-secondary">GitHub 下载</a>
        </div>

        <div class="glass pricing-card pricing-recommended">
          <div class="badge">推荐</div>
          <h3>Pro 团队版</h3>
          <div class="price">¥99<span>/月</span></div>
          <ul class="feature-list">
            <li>全部 Lite 功能</li>
            <li>多人并发（20人）</li>
            <li>SQLite WAL 模式</li>
            <li>团队看板 + 会话查询</li>
            <li>云端规则自动更新</li>
            <li>日/周/月统计报告</li>
            <li>邮件技术支持</li>
          </ul>
          <a href="#buy-pro" class="btn btn-primary">立即购买</a>
        </div>

        <div class="glass pricing-card">
          <h3>Enterprise 企业版</h3>
          <div class="price">定制<span>年费</span></div>
          <ul class="feature-list">
            <li>全部 Pro 功能</li>
            <li>100+ 人高并发</li>
            <li>Redis 集群存储</li>
            <li>AC 自动机（万级词库）</li>
            <li>审计日志 + 告警</li>
            <li>权限控制 (RBAC)</li>
            <li>驻场支持 + SLA</li>
          </ul>
          <a href="#contact" class="btn btn-secondary">联系我们</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq">
    <div class="container">
      <h2 class="section-title">常见问题</h2>

      <div class="faq-list">
        <div class="glass faq-item">
          <h4>如何接入？</h4>
          <p>只需将 AI 客户端的 API 地址从 https://api.openai.com 改为 http://localhost:9999，其他完全不变。</p>
        </div>

        <div class="glass faq-item">
          <h4>数据安全吗？</h4>
          <p>所有敏感数据仅存储在本地 SQLite，映射关系不上传任何云端，支持一键物理销毁。</p>
        </div>

        <div class="glass faq-item">
          <h4>支持哪些 AI 服务？</h4>
          <p>支持所有兼容 OpenAI API 格式的服务：DeepSeek、Claude、ChatGPT、Cursor、飞书机器人等。</p>
        </div>

        <div class="glass faq-item">
          <h4>如何部署？</h4>
          <p>Docker 一键部署：docker-compose up -d。或下载 Windows/macOS 单文件直接运行。</p>
        </div>

        <div class="glass faq-item">
          <h4>Pro 版如何激活？</h4>
          <p>购买后收到 License Key，在管理后台填写即可激活。License 绑定硬件指纹，防止滥用。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta">
    <div class="gradient-orb gradient-orb-1"></div>
    <div class="container">
      <h2>立即保护你的 AI 数据</h2>
      <p>30 秒安装，马上生效</p>
      <div class="cta-buttons">
        <a href="https://github.com/gunxueqiu6/ai-privacy-gateway" class="btn btn-primary">免费开始</a>
        <a href="#pricing" class="btn btn-secondary">查看定价</a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <h3>AI Privacy Gateway</h3>
          <p>保护 AI 请求中的敏感数据</p>
        </div>
        <div class="footer-links">
          <a href="https://github.com/gunxueqiu6/ai-privacy-gateway">GitHub</a>
          <a href="/docs/">文档</a>
          <a href="#pricing">定价</a>
          <a href="#contact">联系</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 AI Privacy Gateway. MIT License.</p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 1rem;
    overflow: hidden;
  }

  .hero-content {
    max-width: 800px;
  }

  .hero h1 {
    font-size: 4rem;
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .highlight {
    color: var(--danger);
  }

  .hero-subtitle {
    font-size: 1.5rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .supported-platforms {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  /* Section Title */
  .section-title {
    text-align: center;
    margin-bottom: 4rem;
    color: var(--primary);
  }

  /* Problems */
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .problem-card {
    padding: 2rem;
    text-align: center;
  }

  .problem-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .problem-card h3 {
    margin-bottom: 0.5rem;
  }

  .problem-card p {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  /* Features Bento */
  .features-bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .feature-card {
    padding: 1.5rem;
  }

  .feature-large {
    grid-column: span 2;
  }

  .feature-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .feature-card h3 {
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .feature-demo {
    margin-top: 1rem;
    padding: 0.75rem;
    background: var(--bg-deep);
    border-radius: 8px;
  }

  .feature-demo code {
    font-size: 0.85rem;
    color: var(--primary);
  }

  /* How It Works */
  .steps {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .step-card {
    padding: 1.5rem;
    text-align: center;
    min-width: 180px;
  }

  .step-number {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, var(--primary-dim), var(--primary));
    color: var(--bg-deep);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    margin: 0 auto 1rem;
  }

  .step-card h3 {
    margin-bottom: 0.5rem;
  }

  .step-card p {
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  .step-connector {
    color: var(--primary);
    font-size: 1.5rem;
  }

  /* Pricing */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .pricing-card {
    padding: 2rem;
    text-align: center;
    position: relative;
  }

  .pricing-recommended {
    border-color: var(--primary);
    box-shadow: 0 0 40px var(--primary-glow);
  }

  .badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, var(--primary-dim), var(--primary));
    color: var(--bg-deep);
    padding: 4px 16px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .price {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 1rem 0;
  }

  .price span {
    font-size: 0.5em;
    color: var(--text-muted);
    font-weight: 400;
  }

  .feature-list {
    list-style: none;
    text-align: left;
    margin: 1.5rem 0;
  }

  .feature-list li {
    padding: 0.5rem 0;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .feature-list li::before {
    content: "✓ ";
    color: var(--primary);
    margin-right: 0.5rem;
  }

  .feature-list li.disabled {
    color: var(--text-muted);
    text-decoration: line-through;
  }

  .feature-list li.disabled::before {
    content: "✗ ";
    color: var(--danger);
  }

  /* FAQ */
  .faq-list {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    padding: 1.5rem;
  }

  .faq-item h4 {
    color: var(--primary);
    margin-bottom: 0.5rem;
  }

  .faq-item p {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  /* CTA */
  .cta {
    text-align: center;
    padding: 6rem 0;
    position: relative;
    overflow: hidden;
  }

  .cta h2 {
    margin-bottom: 1rem;
  }

  .cta p {
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  /* Footer */
  footer {
    padding: 4rem 0 2rem;
    border-top: 1px solid var(--border);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .footer-brand h3 {
    font-size: 1.25rem;
    margin-bottom: 0.25rem;
  }

  .footer-brand p {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .footer-links {
    display: flex;
    gap: 2rem;
  }

  .footer-links a {
    color: var(--text-secondary);
  }

  .footer-links a:hover {
    color: var(--primary);
  }

  .footer-bottom {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .features-bento {
      grid-template-columns: repeat(2, 1fr);
    }

    .feature-large {
      grid-column: span 1;
    }
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2.5rem;
    }

    .problem-grid,
    .pricing-grid {
      grid-template-columns: 1fr;
    }

    .features-bento {
      grid-template-columns: 1fr;
    }

    .steps {
      flex-direction: column;
    }

    .step-connector {
      transform: rotate(90deg);
    }

    .footer-content {
      flex-direction: column;
      gap: 1.5rem;
      text-align: center;
    }
  }
</style>
