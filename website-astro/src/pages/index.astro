  .perf-fill-accent { background: linear-gradient(90deg, rgba(167, 139, 250, 0.6), var(--accent)); }
  .perf-fill-green { background: linear-gradient(90deg, var(--primary-dim), #4ade80); }

  .perf-bar-val {
    font-size: 0.72rem;
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
    min-width: 3rem;
    text-align: right;
  }

  /* =============================================
     COMPATIBILITY
     ============================================= */
  .compat { padding: 6rem 0; }

