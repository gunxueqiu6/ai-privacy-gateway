  .chip-loc { background: rgba(252, 165, 165, 0.12); color: #fca5a5; }
  .chip-org { background: rgba(148, 163, 184, 0.12); color: #94a3b8; }
  .chip-more { background: rgba(255, 255, 255, 0.04); color: var(--text-muted); }

  .bento-metrics {
    display: flex;
    gap: 2rem;
    padding-top: 1.5rem;
    margin-top: 1.5rem;
    border-top: 1px solid var(--border);
