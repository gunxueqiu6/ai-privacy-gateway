---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="AI Privacy Gateway — 你的 AI 数据正在裸奔，30 秒装上防火墙"
  description="开源的 AI API 隐私隔离网关。自动识别并脱敏发给 AI 的手机号、邮箱、身份证、银行卡、API Key 等敏感信息。支持 Cursor、DeepSeek、Kimi、通义千问等所有 OpenAI 兼容 API。Lite 版永久免费。"
  canonicalURL="https://privacygw.pages.dev">
  <Nav />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-code-bg"></div>
    <div class="hero-orb orb-enhanced"></div>
    <div class="hero-orb-secondary orb-enhanced-2"></div>
    <div class="container hero-content">
      <div class="hero-text">
        <div class="hero-badge">
          <span class="badge-dot"></span>
          <span>v1.1.0 开源版</span>
        </div>
        <h1 class="hero-title">
          保护你的
          <span class="gradient-text">AI 数据</span>
          隐私
        </h1>
        <p class="hero-description">
          30 秒部署防火墙，自动脱敏所有流向 AI 的敏感数据。
          支持 DeepSeek、Claude、ChatGPT、Cursor 等所有主流服务。
        </p>
        <div class="hero-actions">
          <a href="/download" class="btn btn-primary">立即开始</a>
          <a href="https://github.com/gunxueqiu6/ai-privacy-gateway" class="btn btn-ghost">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
        </div>
        <div class="hero-stats reveal reveal-up">
          <div class="stat-item">
            <span class="stat-value stat-value-animated" data-count="14">14</span>
            <span class="stat-label">实体类型</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-value stat-value-animated" data-count="93">93%</span>
            <span class="stat-label">引擎覆盖率</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-value stat-value-animated" data-count="0">0</span>
            <span class="stat-label">数据上传</span>
          </div>
        </div>
      </div>
      <div class="hero-code glass code-block-glow">
        <div class="code-header">
          <span class="code-dot code-dot-red"></span>
          <span class="code-dot code-dot-yellow"></span>
          <span class="code-dot code-dot-green"></span>
        </div>
        <pre class="code-content"><code><span class="code-comment"># 只需修改 API 地址</span>
<span class="code-keyword">import</span> openai

<span class="code-comment"># 从这里</span>
openai.api_base = <span class="code-string">"https://api.openai.com/v1"</span>

<span class="code-comment"># 改成这里</span>
openai.api_base = <span class="code-string">"http://localhost:9999/v1"</span>

<span class="code-comment"># 敏感数据自动脱敏，无需改动任何代码</span></code></pre>
      </div>
    </div>
  </section>

  <!-- 问题区 -->
  <section class="problem">
    <div class="container">
      <h2 class="section-title reveal reveal-up">为什么需要保护？</h2>
      <div class="problem-grid reveal-stagger">
        <div class="problem-card glass glass-hover reveal reveal-up">
          <div class="problem-icon-wrap">
            <svg class="problem-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3>数据裸奔</h3>
          <p>每次调用 AI，你的手机号、邮箱、身份证等敏感信息都在裸奔</p>
        </div>
        <div class="problem-card glass glass-hover reveal reveal-up">
          <div class="problem-icon-wrap">
            <svg class="problem-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <h3>历史泄露</h3>
          <p>大模型训练会记住你的数据，可能在未来泄露给其他用户</p>
        </div>
        <div class="problem-card glass glass-hover reveal reveal-up">
          <div class="problem-icon-wrap">
            <svg class="problem-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <h3>合规风险</h3>
          <p>未经脱敏的用户数据流向第三方，违反数据保护法规</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 功能 Bento -->
  <section class="features" id="features">
    <div class="container">
      <h2 class="section-title reveal reveal-up">核心功能</h2>
      <div class="bento-grid">
        <div class="bento-card glass bento-feature glow-hover">
          <div class="bento-badge">核心引擎</div>
          <div class="bento-icon-large">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3 class="bento-title-large">智能脱敏引擎 <span class="tier-badge tier-lite">Lite</span></h3>
          <p class="bento-desc">正则 + NER 双引擎识别 14 类敏感实体。手机号、身份证、邮箱、银行卡、姓名、地址、车牌、IP、URL、日期、金额、邮编、组织机构、自定义关键词 — 自动检测，零配置。</p>
          <div class="bento-stats">
            <div class="bento-stat">
              <span class="bento-stat-num">14</span>
              <span class="bento-stat-label">实体类型</span>
            </div>
            <div class="bento-stat">
              <span class="bento-stat-num">&lt;1ms</span>
              <span class="bento-stat-label">检测延迟</span>
            </div>
            <div class="bento-stat">
              <span class="bento-stat-num">93%</span>
              <span class="bento-stat-label">引擎覆盖率</span>
            </div>
          </div>
        </div>
        <div class="bento-card glass glow-hover">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4 17 10 11 4 5"/>
              <line x1="12" y1="19" x2="20" y2="19"/>
            </svg>
          </div>
          <h3>流式支持 <span class="tier-badge tier-lite">Lite</span></h3>
          <p>完美代理 SSE 流式响应，实时脱敏/还原，零延迟感知</p>
        </div>
        <div class="bento-card glass glow-hover bento-tall">
          <div class="bento-card-inner">
            <div class="bento-badge">架构</div>
            <div class="bento-icon-large">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"/>
                <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
              </svg>
            </div>
            <h3 class="bento-title-large">数据流架构</h3>
            <p class="bento-desc">请求进入网关后经正则匹配、NER 识别、映射替换三层处理，脱敏后转发 AI。响应返回时逆向还原，全程低于 1ms 附加延迟。</p>
            <div class="flow-diagram">
              <div class="flow-node">
                <span class="flow-dot"></span>
                <span>Client</span>
              </div>
              <div class="flow-arrow">&rarr;</div>
              <div class="flow-node flow-node-accent">
                <span class="flow-dot"></span>
                <span>Gateway</span>
              </div>
              <div class="flow-arrow">&rarr;</div>
              <div class="flow-node">
                <span class="flow-dot"></span>
                <span>LLM</span>
              </div>
            </div>
            <div class="flow-sub">
              <span class="flow-tag">正则匹配</span>
              <span class="flow-tag">NER 识别</span>
              <span class="flow-tag">映射替换</span>
            </div>
          </div>
        </div>
        <div class="bento-card glass glow-hover">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            </svg>
          </div>
          <h3>本地存储 <span class="tier-badge tier-lite">Lite</span></h3>
          <p>SQLite 本地加密存储，映射数据永不离开你的机器</p>
        </div>
        <div class="bento-card glass glow-hover">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h3>30 秒部署 <span class="tier-badge tier-lite">Lite</span></h3>
          <p>单二进制文件，下载即用。Docker / pip / 手动运行皆可</p>
        </div>
        <div class="bento-card glass glow-hover">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </div>
          <h3>自定义规则 <span class="tier-badge tier-lite">Lite</span></h3>
          <p>支持正则 + 关键词自定义脱敏规则，灵活适配业务需求</p>
        </div>
        <div class="bento-card glass glow-hover">
          <div class="bento-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <h3>管理后台 <span class="tier-badge tier-lite">Lite</span></h3>
          <p>实时统计面板，查看脱敏次数、实体分布、映射记录</p>
        </div>
        <div class="bento-card glass glow-hover bento-wide">
          <div class="bento-card-inner" style="display:flex;flex-direction:row;gap:2rem;align-items:center;">
            <div style="flex-shrink:0;">
              <div class="bento-icon-large">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:32px;height:32px;">
                  <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                </svg>
              </div>
            </div>
            <div style="flex:1;">
              <h3 class="bento-title-large">性能指标</h3>
              <p class="bento-desc" style="margin-bottom:0.5rem;">P99 延迟 2ms，单机吞吐 10,000+ QPS，零数据上传至第三方</p>
              <div class="perf-bar-group">
                <div class="perf-bar-item">
                  <span class="perf-bar-label">正则匹配</span>
                  <div class="perf-bar-track">
                    <div class="perf-bar-fill" style="width:95%;"></div>
                  </div>
                  <span class="perf-bar-value">0.3ms</span>
                </div>
                <div class="perf-bar-item">
                  <span class="perf-bar-label">NER 识别</span>
                  <div class="perf-bar-track">
                    <div class="perf-bar-fill perf-bar-accent" style="width:88%;"></div>
                  </div>
                  <span class="perf-bar-value">0.8ms</span>
                </div>
                <div class="perf-bar-item">
                  <span class="perf-bar-label">映射还原</span>
                  <div class="perf-bar-track">
                    <div class="perf-bar-fill perf-bar-green" style="width:98%;"></div>
                  </div>
                  <span class="perf-bar-value">0.1ms</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 工作原理 -->
  <section class="how-it-works" id="how-it-works">
    <div class="container">
      <h2 class="section-title reveal reveal-up">工作原理</h2>
      <div class="steps-container reveal reveal-up">
        <div class="step-item">
          <div class="step-number">01</div>
          <div class="step-card glass">
            <h3>请求拦截</h3>
            <p>网关拦截所有发往 AI 的请求，识别其中的敏感数据</p>
          </div>
        </div>
        <div class="step-connector">
          <div class="connector-line"></div>
          <div class="connector-dot"></div>
        </div>
        <div class="step-item">
          <div class="step-number">02</div>
          <div class="step-card glass">
            <h3>自动脱敏</h3>
            <p>将敏感数据替换为唯一占位符，映射关系存储在本地数据库</p>
          </div>
        </div>
        <div class="step-connector">
          <div class="connector-line"></div>
          <div class="connector-dot"></div>
        </div>
        <div class="step-item">
          <div class="step-number">03</div>
          <div class="step-card glass">
            <h3>响应还原</h3>
            <p>接收 AI 响应，将占位符还原为原始数据后返回给客户端</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 全平台覆盖 -->
  <section class="platforms">
    <div class="container">
      <h2 class="section-title reveal reveal-up">全平台覆盖</h2>
      <p class="platforms-subtitle">一套网关，所有平台 SDK 开箱即用</p>
      <div class="platforms-grid reveal-stagger">
        <div class="platform-card glass glass-hover reveal reveal-up">
          <div class="platform-icon-wrap">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M15.4 2.4C18.3 4.5 20.5 8.2 20.5 12c0 3.8-2.2 7.5-5.1 9.6-.3.2-.6.4-.9.6l-.6-1.2c.3-.2.6-.4.8-.6 2.4-1.8 4.1-5.3 4.1-8.4s-1.7-6.6-4.1-8.4c-.3-.2-.5-.4-.8-.6l.6-1.2c.3.2.6.4.9.6zM8.6 2.4c.3.2.6.4.9.6l.6 1.2c-.3.2-.6.4-.8.6C6.9 6.6 5.6 10.1 5.6 12s1.3 5.4 3.7 7.2c.3.2.5.4.8.6l-.6 1.2c-.3-.2-.6-.4-.9-.6C5.7 18.4 3.5 14.7 3.5 12s2.2-6.4 5.1-9.6zM12 2c1.1 0 2 .9 2 2v16c0 1.1-.9 2-2 2s-2-.9-2-2V4c0-1.1.9-2 2-2z"/>
            </svg>
          </div>
          <h3>Python SDK</h3>
          <p>pip install，一行代码接入</p>
        </div>
        <div class="platform-card glass glass-hover reveal reveal-up">
          <div class="platform-icon-wrap">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.4 0-8-3.6-8-8s3.6-8 8-8 8 3.6 8 8-3.6 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
            </svg>
          </div>
          <h3>JavaScript SDK</h3>
          <p>npm install，前端/Node 通用</p>
        </div>
        <div class="platform-card glass glass-hover reveal reveal-up">
          <div class="platform-icon-wrap">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.5 2h-11C5.1 2 4 3.1 4 4.5v15C4 20.9 5.1 22 6.5 22h11c1.4 0 2.5-1.1 2.5-2.5v-15C20 3.1 18.9 2 17.5 2zM12 20c-.8 0-1.5-.7-1.5-1.5S11.2 17 12 17s1.5.7 1.5 1.5S12.8 20 12 20zm5-4H7V5h10v11z"/>
            </svg>
          </div>
          <h3>Flutter SDK</h3>
          <p>跨平台移动端原生集成</p>
        </div>
        <div class="platform-card glass glass-hover reveal reveal-up">
          <div class="platform-icon-wrap">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M6 18c0 .6.4 1 1 1h2c.6 0 1-.4 1-1v-2H6v2zM14 18c0 .6.4 1 1 1h2c.6 0 1-.4 1-1v-2h-4v2zM4 8v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8H4zm16-2V4c0-1.1-.9-2-2-2H6C4.9 2 4 2.9 4 4v2h16z"/>
              <rect x="8" y="10" width="3" height="4" rx="0.5"/>
              <rect x="13" y="10" width="3" height="4" rx="0.5"/>
            </svg>
          </div>
          <h3>Android SDK</h3>
          <p>原生 Kotlin，Gradle 一键引入</p>
        </div>
        <div class="platform-card glass glass-hover reveal reveal-up">
          <div class="platform-icon-wrap">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.7 1.3c-.4-.4-1-.4-1.4 0l-2 2c-.4.4-.4 1 0 1.4.4.4 1 .4 1.4 0l2-2c.4-.4.4-1 0-1.4zM3.9 3.9c-.4.4-.4 1 0 1.4l2 2c.4.4 1 .4 1.4 0 .4-.4.4-1 0-1.4l-2-2c-.4-.4-1-.4-1.4 0zm11.3 2.8L8.9 13c-.4.4-.4 1 0 1.4.4.4 1 .4 1.4 0l6.3-6.3c.4-.4.4-1 0-1.4-.4-.4-1-.4-1.4 0zM20 12c-.6 0-1 .4-1 1v6H5V5h6c.6 0 1-.4 1-1s-.4-1-1-1H4c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2v-8c0-.6-.4-1-1-1z"/>
            </svg>
          </div>
          <h3>iOS SDK</h3>
          <p>原生 Swift，SPM 一键集成</p>
        </div>
        <div class="platform-card glass glass-hover reveal reveal-up">
          <div class="platform-icon-wrap">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
            </svg>
          </div>
          <h3>浏览器扩展</h3>
          <p>Chrome / Edge 一键安装，网页端即装即用</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="cta-orb orb-enhanced"></div>
    <div class="cta-orb-secondary orb-enhanced-2"></div>
    <div class="cta-tertiary-orb"></div>
    <div class="container cta-content">
      <h2 class="cta-title">
        现在开始保护你的
        <span class="gradient-text">AI 数据隐私</span>
      </h2>
      <p class="cta-description">
        无需复杂配置，只需修改 API 地址即可启用
      </p>
      <div class="cta-actions">
        <a href="/download" class="btn btn-primary">立即下载</a>
        <a href="https://github.com/gunxueqiu6/ai-privacy-gateway" class="btn btn-ghost btn-ghost-light">GitHub</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ===========================================
     Hero
     =========================================== */
  .hero {
