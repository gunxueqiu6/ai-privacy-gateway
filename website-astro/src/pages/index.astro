  .perf-bar-label {
    font-size: 0.72rem;
    color: var(--text-secondary);
    min-width: 5.5rem;
    flex-shrink: 0;
  }

  .perf-bar-track {
    flex: 1;
    height: 6px;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 3px;
    overflow: hidden;
