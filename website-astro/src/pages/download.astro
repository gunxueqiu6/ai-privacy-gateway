---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="下载 AI Privacy Gateway — Docker / Windows / macOS / 浏览器扩展"
  description="下载 AI Privacy Gateway 客户端和浏览器扩展。支持 Docker 镜像、Windows .exe、macOS 便携版、Chrome/Edge 扩展。30 秒部署，保护你发给 AI 的敏感数据。"
  keywords="下载AI隐私网关,Docker部署隐私代理,Windows隐私保护工具,macOS数据脱敏,Chrome扩展隐私,浏览器隐私插件"
  canonicalURL="https://privacygw.pages.dev/download">
  <Nav />

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        <span>v2.0.0</span>
      </div>
      <h1 class="hero-title">
        下载 <span class="gradient-text">Privacy Gateway</span>
      </h1>
      <p class="hero-description">
        一条命令部署，双击即用。无需配置，自动生成密钥。<br/>
        MIT 许可证开源免费。
      </p>
    </div>
  </section>

  <!-- Primary Download — Windows Installer -->
  <section class="download-section">
    <div class="container">

      <!-- Windows Installer — recommended -->
      <div class="primary-download glass">
        <div class="primary-badge">Recommended</div>
        <div class="primary-content">
          <div class="primary-icon-wrap">
            <span class="primary-icon">⊞</span>
          </div>
          <div class="primary-text">
            <h2>Download for Windows</h2>
            <p class="primary-desc">Standalone executable. No install required — just download and run.</p>
            <div class="primary-meta">
              <span>Windows 10 / 11</span>
              <span>&middot;</span>
              <span>64-bit</span>
              <span>&middot;</span>
              <span>Free &amp; Open Source</span>
            </div>
          </div>
          <a href="https://github.com/gunxueqiu6/ai-privacy-gateway/releases/download/v2.0.0/PrivacyGateway.exe" class="btn btn-primary btn-large">
            Download (.exe)
          </a>
        </div>
      </div>

      <!-- Other platforms -->
      <div class="download-grid">
        <div class="download-card glass">
          <div class="download-icon-wrap">
            <span class="download-icon">&#8984;</span>
          </div>
          <h2>macOS (.dmg)</h2>
          <p>Build from source on macOS</p>
          <div class="code-block">
            <pre><code>git clone https://github.com/gunxueqiu6/ai-privacy-gateway
cd ai-privacy-gateway
bash packaging/macos/build_dmg.sh</code></pre>
          </div>
          <p class="download-hint">Requires macOS 10.15+. DMG output in <code>packaging/macos/output/</code></p>
          <a href="https://github.com/gunxueqiu6/ai-privacy-gateway" class="btn btn-outline btn-block">View on GitHub</a>
        </div>

        <div class="download-card glass">
          <div class="download-icon-wrap">
            <span class="download-icon">&#9635;</span>
          </div>
          <h2>Docker</h2>
          <p>Server deployment, one command</p>
          <div class="code-block">
            <pre><code>docker run -d --name ai-privacy-gw -p 9999:9999 -v ./vault_data:/app/vault_data ghcr.io/gunxueqiu6/ai-privacy-gateway:lite</code></pre>
          </div>
          <p class="download-hint">Also supports docker-compose up -d</p>
          <a href="https://github.com/gunxueqiu6/ai-privacy-gateway#docker" class="btn btn-outline btn-block">View Docs</a>
        </div>

        <div class="download-card glass">
          <div class="download-icon-wrap">
            <span class="download-icon">&lt;/&gt;</span>
          </div>
          <h2>pip Install</h2>
          <p>Python developers, one pip command</p>
          <div class="code-block">
            <pre><code>pip install -r requirements.txt
python start.py --auto</code></pre>
          </div>
          <p class="download-hint">Requires Python 3.8+</p>
          <a href="https://github.com/gunxueqiu6/ai-privacy-gateway" class="btn btn-outline btn-block">GitHub</a>
        </div>

        <div class="download-card glass">
          <div class="download-icon-wrap">
            <span class="download-icon">&#127760;</span>
          </div>
          <h2>Browser Extension</h2>
          <p>Chrome / Edge plugin</p>
          <a href="https://github.com/gunxueqiu6/ai-privacy-gateway/releases/download/v2.0.0/ai-privacy-gateway-extension-v2.0.0.zip" class="btn btn-primary btn-block">
            Download v2.0.0
          </a>
          <p class="download-hint" style="margin-top:0.5rem;">
            Unzip &rarr; <code>chrome://extensions</code> &rarr; Developer mode &rarr; Load unpacked
          </p>
        </div>
      </div>

      <!-- Advanced Options -->
      <details class="advanced-section glass">
        <summary class="advanced-summary">Advanced Options &mdash; Source code &amp; manual setup</summary>
        <div class="advanced-content">
          <div class="advanced-grid">
            <div class="advanced-card">
              <h3>Windows (ZIP / portable)</h3>
              <p>No installer, just the executable.</p>
              <div class="code-block">
                <pre><code>git clone https://github.com/gunxueqiu6/ai-privacy-gateway
cd ai-privacy-gateway
start.bat</code></pre>
              </div>
              <p class="download-hint">Or download ZIP, extract, double-click <code>start.bat</code></p>
              <a href="https://github.com/gunxueqiu6/ai-privacy-gateway/archive/refs/heads/master.zip" class="btn btn-outline btn-block">Download ZIP</a>
            </div>
            <div class="advanced-card">
              <h3>macOS / Linux (portable)</h3>
              <p>From source, works on any Unix system.</p>
              <div class="code-block">
                <pre><code>git clone https://github.com/gunxueqiu6/ai-privacy-gateway
cd ai-privacy-gateway
bash start.sh</code></pre>
              </div>
              <p class="download-hint">Also <code>chmod +x start.sh && ./start.sh</code></p>
              <a href="https://github.com/gunxueqiu6/ai-privacy-gateway/archive/refs/heads/master.zip" class="btn btn-outline btn-block">Download ZIP</a>
            </div>
          </div>
        </div>
      </details>

      <!-- Quick Start -->
      <div class="quick-start glass">
        <h3>30 秒快速开始</h3>
        <div class="steps">
          <div class="step">
            <span class="step-num">1</span>
            <div>
              <h4>下载并启动</h4>
              <p>运行可执行文件或 Docker 容器</p>
            </div>
          </div>
          <div class="step-connector">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
          <div class="step">
            <span class="step-num">2</span>
            <div>
              <h4>修改 API 地址</h4>
              <p>改为 <code>http://localhost:9999/v1</code></p>
            </div>
          </div>
          <div class="step-connector">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
          <div class="step">
            <span class="step-num">3</span>
            <div>
              <h4>完成</h4>
              <p>敏感数据自动脱敏，无需其他配置</p>
            </div>
          </div>
        </div>
      </div>

    <Footer />
</Layout>

<style>
  .hero {
    padding: 10rem 0 4rem;
    position: relative;
  }
  .hero-content { text-align: center; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--bg-surface); padding: 0.5rem 1rem; border-radius: 20px;
    font-size: 0.875rem; font-weight: 500; color: var(--primary); margin-bottom: 1.5rem;
  }
  .badge-dot { width: 8px; height: 8px; background: var(--primary); border-radius: 50%; animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
  .hero-title { font-size: 3.5rem; font-weight: 700; letter-spacing: -0.04em; margin-bottom: 1.5rem; line-height: 1.15; }
  .gradient-text {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .hero-description { font-size: 1.125rem; color: var(--text-secondary); line-height: 1.8; max-width: 560px; margin: 0 auto; }

  .download-section { padding: 4rem 0 6rem; max-width: 960px; margin: 0 auto; }

  /* Primary Download Card */
  .primary-download {
    padding: 2.5rem;
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(56, 189, 248, 0.2);
  }
  .primary-download::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(56, 189, 248, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .primary-badge {
    display: inline-block;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.75rem;
    border-radius: 4px;
    margin-bottom: 1.25rem;
  }
  .primary-content {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .primary-icon-wrap {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: rgba(56, 189, 248, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .primary-icon {
    font-size: 1.75rem;
    color: var(--primary);
    font-weight: 700;
  }
  .primary-text {
    flex: 1;
    min-width: 200px;
  }
  .primary-text h2 {
    margin-bottom: 0.25rem;
    font-size: 1.5rem;
  }
  .primary-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }
  .primary-meta {
    color: var(--text-tertiary, #888);
    font-size: 0.8rem;
    display: flex;
    gap: 0.4rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .btn-large {
    padding: 0.85rem 2rem;
    font-size: 1rem;
    flex-shrink: 0;
    white-space: nowrap;
  }
  @media (max-width: 768px) {
    .primary-content { flex-direction: column; align-items: flex-start; }
    .btn-large { width: 100%; text-align: center; }
    .primary-text { min-width: auto; }
  }

  .download-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .download-card { padding: 2rem; text-align: center; position: relative; }
  .download-card h2 { margin-bottom: 0.5rem; }
  .download-card p { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1rem; }
  .download-icon-wrap {
    width: 56px; height: 56px; border-radius: 14px;
    background: rgba(134, 239, 172, 0.08);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1rem;
  }
  .download-icon { font-size: 1.5rem; color: var(--primary); font-weight: 700; }

  .coming-soon-badge {
    display: inline-block;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-tertiary, #888);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.4rem 1rem;
    border-radius: 20px;
    cursor: default;
  }

  .download-hint { font-size: 0.8rem; color: var(--text-tertiary, #888); margin-top: 0.5rem; }
  .download-hint code { background: var(--bg-deep); padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.75rem; color: var(--primary); font-family: 'Fira Code', monospace; }

  .code-block {
    background: var(--bg-deep); border: 1px solid var(--border);
    border-radius: 8px; padding: 0.75rem; margin-bottom: 1rem; overflow-x: auto; text-align: left;
  }
  .code-block pre { margin: 0; font-size: 0.85rem; }
  .code-block code { color: var(--primary); font-family: 'Fira Code', monospace; }

  .btn-outline {
    background: transparent; color: var(--text-primary);
    border: 1px solid var(--border); padding: 0.75rem 1.5rem;
  }
  @media (hover: hover) {
    .btn-outline:hover { border-color: var(--primary); color: var(--primary); }
  }
  .btn-block { width: 100%; }

  .advanced-section {
    padding: 0;
    margin-bottom: 3rem;
    overflow: hidden;
  }
  .advanced-summary {
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--text-secondary);
    user-select: none;
    list-style: none;
  }
  .advanced-summary::-webkit-details-marker { display: none; }
  .advanced-summary::before {
    content: '\25B6';
    display: inline-block;
    margin-right: 0.5rem;
    transition: transform 0.2s ease;
    font-size: 0.65rem;
    color: var(--text-tertiary);
  }
  details[open] .advanced-summary::before {
    transform: rotate(90deg);
  }
  .advanced-summary:hover { color: var(--primary); }
  .advanced-content { padding: 0 1.5rem 1.5rem; }
  .advanced-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .advanced-card { }
  .advanced-card h3 { font-size: 0.95rem; margin-bottom: 0.5rem; }
  .advanced-card > p { color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 0.75rem; }

  .quick-start { padding: 2.5rem; margin-bottom: 3rem; text-align: center; }
  .quick-start h3 { margin-bottom: 2rem; }
  .steps {
    display: flex; align-items: center; justify-content: center;
    gap: 1.5rem; flex-wrap: wrap;
  }
  .step { flex: 1; min-width: 200px; display: flex; gap: 1rem; text-align: left; }
  .step-num {
    width: 2.75rem; height: 2.75rem;
    background: linear-gradient(135deg, var(--primary-dim), var(--primary));
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-weight: 700; color: var(--bg-deep); flex-shrink: 0; font-size: 1.1rem;
  }
  .step h4 { margin-bottom: 0.25rem; }
  .step p { color: var(--text-secondary); font-size: 0.9rem; }
  .step code {
    background: var(--bg-deep); padding: 0.2rem 0.5rem; border-radius: 4px;
    font-size: 0.8rem; color: var(--primary); font-family: 'Fira Code', monospace;
  }
  .step-connector {
    color: var(--primary); width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .step-connector svg { width: 20px; height: 20px; }

  @media (max-width: 1024px) {
    .download-section { max-width: 100%; padding: 3rem 0 5rem; }
  }

  @media (max-width: 768px) {
    .hero-title { font-size: 2.25rem; }
    .hero-description { font-size: 1rem; }
    .download-grid { grid-template-columns: 1fr; }
    .steps { flex-direction: column; }
    .step-connector { transform: rotate(90deg); }
    .code-block pre { font-size: 0.75rem; }
    .quick-start { padding: 1.5rem; }
    .advanced-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 639px) {
    .hero { padding: 6rem 0 3rem; }
    .hero-title { font-size: 2rem; }
    .download-section { padding: 2rem 0 4rem; }
    .step { min-width: auto; }
    .step-connector { transform: rotate(90deg); }
    .code-block pre { font-size: 0.65rem; }
    .steps { gap: 1rem; }
  }

  @media (max-width: 375px) {
    .hero-title { font-size: 1.75rem; }
    .download-card { padding: 1.5rem 1rem; }
  }
</style>
