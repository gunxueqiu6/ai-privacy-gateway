---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="文档中心 - AI Privacy Gateway">
  <Nav />

  <div class="page-header">
    <h1>文档中心</h1>
    <p>快速上手、部署配置、API 参考</p>
  </div>

  <section>
    <div class="docs-grid">
      <a href="/docs/quickstart" class="docs-card glass">
        <div class="idx">01</div>
        <h3>快速开始</h3>
        <p>5 分钟部署，Docker / Windows / macOS</p>
      </a>
      <a href="/docs/deploy" class="docs-card glass">
        <div class="idx">02</div>
        <h3>部署指南</h3>
        <p>Docker Compose、裸机部署、systemd</p>
      </a>
      <a href="/docs/config" class="docs-card glass">
        <div class="idx">03</div>
        <h3>配置参考</h3>
        <p>环境变量、脱敏规则、License 激活</p>
      </a>
      <a href="/docs/keywords" class="docs-card glass">
        <div class="idx">04</div>
        <h3>自定义敏感词</h3>
        <p>添加团队专属敏感词、正则模式</p>
      </a>
      <a href="/docs/architecture" class="docs-card glass">
        <div class="idx">05</div>
        <h3>架构说明</h3>
        <p>数据流、SSE 处理、Rust 完整性检查</p>
      </a>
      <a href="/docs/api" class="docs-card glass">
        <div class="idx">06</div>
        <h3>API 参考</h3>
        <p>管理接口、统计查询、License 验证</p>
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .page-header {
    text-align: center;
    padding: 8rem 0 3rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--primary);
  }

  .page-header p {
    font-size: 1.1rem;
    color: var(--text-secondary);
  }

  section {
    padding-bottom: 4rem;
  }

  .docs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .docs-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    display: block;
    color: var(--text-primary);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .docs-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  .docs-card .idx {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .docs-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
    color: var(--primary);
  }

  .docs-card p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .docs-grid { grid-template-columns: 1fr; }
  }
</style>
